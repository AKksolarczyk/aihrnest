<!DOCTYPE html>
<html lang="{{ locale|default('pl') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Smart Desk{% endblock %}</title>
    </head>
    <body style="margin:0;padding:0;background:#f5f5f4;font-family:'Manrope','Segoe UI',Arial,sans-serif;color:#292524;">
        <div style="padding:32px 16px;background:
            radial-gradient(circle at top left, rgba(168,162,158,0.18), transparent 24%),
            radial-gradient(circle at 85% 12%, rgba(120,113,108,0.12), transparent 26%),
            linear-gradient(160deg, #fafaf9 0%, #f5f5f4 46%, #e7e5e4 100%);">
            <div style="max-width:640px;margin:0 auto;">
                <div style="padding:18px 22px;border-radius:24px;border:1px solid rgba(120,113,108,0.18);background:linear-gradient(180deg, rgba(68,64,60,0.92) 0%, rgba(41,37,36,0.9) 100%);box-shadow:0 18px 48px rgba(41,37,36,0.16);">
                    <div style="text-transform:uppercase;letter-spacing:0.18em;color:#d6d3d1;font-size:11px;font-weight:800;margin-bottom:8px;">Smart Desk</div>
                    <div style="font-size:26px;line-height:1.05;font-weight:800;color:#fafaf9;letter-spacing:-0.03em;">{% block hero_title %}Smart Desk{% endblock %}</div>
                    {% if block('hero_lead') is not empty %}
                        <div style="margin-top:10px;font-size:15px;line-height:1.65;color:#e7e5e4;">{% block hero_lead %}{% endblock %}</div>
                    {% endif %}
                </div>

                <div style="margin-top:18px;padding:28px;border-radius:28px;border:1px solid rgba(41,37,36,0.08);background:linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(245,245,244,0.96) 100%);box-shadow:0 24px 64px rgba(41,37,36,0.12);">
                    {% block content %}{% endblock %}
                </div>

                <div style="margin-top:14px;padding:0 10px;font-size:12px;line-height:1.6;color:#78716c;text-align:center;">
                    {{ 'mail.common.footer'|trans({}, null, locale|default('pl')) }}
                </div>
            </div>
        </div>
    </body>
</html>
