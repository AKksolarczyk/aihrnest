{% extends 'email/base.html.twig' %}

{% block title %}{{ 'mail.issue.subject'|trans({}, null, locale) }}{% endblock %}
{% block hero_title %}{{ 'mail.issue.subject'|trans({}, null, locale) }}{% endblock %}
{% block hero_lead %}{{ 'mail.issue.intro'|trans({'%reporter%': reporterName, '%category%': categoryLabel, '%resource%': resourceLabel}, null, locale) }}{% endblock %}

{% block content %}
    <p style="margin:0 0 18px;font-size:16px;line-height:1.7;color:#44403c;">{{ 'mail.issue.greeting'|trans({'%admin%': adminName}, null, locale) }}</p>

    <div style="display:grid;gap:12px;margin:0 0 24px;">
        <div style="padding:16px 18px;border-radius:20px;border:1px solid rgba(239,68,68,0.16);background:rgba(239,68,68,0.07);">
            <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.16em;color:#991b1b;font-weight:800;margin-bottom:6px;">{{ categoryLabel }}</div>
            <div style="font-size:16px;font-weight:800;color:#292524;">{{ resourceLabel }}</div>
            <div style="margin-top:8px;font-size:14px;line-height:1.7;color:#57534e;">
                <strong>{{ 'mail.issue.description_label'|trans({}, null, locale) }}:</strong> {{ description }}
            </div>
        </div>
    </div>

    <div style="margin:0 0 8px;">
        <a href="{{ dashboardUrl }}" style="display:inline-block;padding:14px 20px;border-radius:999px;background:linear-gradient(135deg, #3f3f46 0%, #71717a 100%);color:#fafaf9;text-decoration:none;font-weight:800;box-shadow:0 18px 30px rgba(63,63,70,0.22);">
            {{ 'mail.issue.cta'|trans({}, null, locale) }}
        </a>
    </div>
{% endblock %}
