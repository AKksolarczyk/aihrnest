{% extends 'base.html.twig' %}

{% block title %}DeskFlow{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --bg: #f4efe7;
            --panel: rgba(255, 251, 245, 0.95);
            --panel-strong: #fff8ee;
            --ink: #1f2937;
            --muted: #6b7280;
            --line: #d9c7b3;
            --accent: #b85c38;
            --accent-deep: #6f2f1d;
            --accent-soft: #f0dfcf;
            --success: #2f6b4f;
            --warning: #c97a12;
            --danger: #9f2d2d;
            --shadow: 0 18px 50px rgba(96, 62, 38, 0.12);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Georgia, "Times New Roman", serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(184, 92, 56, 0.18), transparent 30%),
                linear-gradient(135deg, #f7f1e8 0%, #efe3d0 100%);
        }

        h1, h2, h3, p { margin-top: 0; }

        .page {
            width: min(1240px, calc(100% - 32px));
            margin: 0 auto;
            padding: 32px 0 48px;
        }

        .shell {
            display: grid;
            gap: 22px;
        }

        .panel {
            background: var(--panel);
            border: 1px solid rgba(111, 47, 29, 0.12);
            border-radius: 24px;
            padding: 24px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(8px);
        }

        .tabs {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 6px;
        }

        .tab {
            margin: 0;
        }

        .tab button {
            border: 1px solid var(--line);
            background: #fff;
            color: var(--accent-deep);
            border-radius: 999px;
            padding: 12px 18px;
            cursor: pointer;
            min-width: 180px;
            text-align: left;
        }

        .tab button.active {
            background: linear-gradient(135deg, var(--accent) 0%, #cc7f4e 100%);
            color: #fff8f2;
            border-color: transparent;
        }

        .tab strong,
        .tab span {
            display: block;
        }

        .tab span {
            font-size: 0.85rem;
            opacity: 0.85;
            margin-top: 4px;
        }

        .tab small {
            display: block;
            font-size: 0.78rem;
            margin-top: 8px;
            opacity: 0.9;
        }

        .hero {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.45fr 0.95fr;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--accent);
            font-size: 12px;
            margin-bottom: 12px;
        }

        .lead {
            font-size: 1.05rem;
            line-height: 1.6;
            max-width: 58ch;
            color: #403a35;
        }

        .chip-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .chip,
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 999px;
            font-size: 0.84rem;
            border: 1px solid var(--line);
        }

        .chip {
            background: #fff;
        }

        .pill {
            background: #efe3d0;
        }

        .pill.schedule { color: var(--accent-deep); }
        .pill.claim { color: var(--success); }
        .pill.vacation { color: var(--warning); }
        .pill.none { color: var(--muted); }

        .stats {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            margin-top: 24px;
        }

        .stat {
            padding: 16px;
            border-radius: 18px;
            background: #f1e5d7;
            border: 1px solid rgba(111, 47, 29, 0.12);
        }

        .stat strong {
            display: block;
            font-size: 1.85rem;
            margin-bottom: 6px;
        }

        .stack,
        .table-like,
        form {
            display: grid;
            gap: 14px;
        }

        .meta-list,
        .week {
            display: grid;
            gap: 12px;
        }

        .meta-item {
            padding: 14px 16px;
            border-radius: 18px;
            border: 1px solid var(--line);
            background: var(--panel-strong);
        }

        .meta-item strong,
        .week-day strong {
            display: block;
            margin-bottom: 4px;
        }

        .content {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.15fr 0.85fr;
        }

        .week {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .week-day {
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 14px;
            background: #fff;
        }

        .rooms {
            display: grid;
            gap: 18px;
        }

        .room-grid {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            margin-top: 16px;
        }

        .desk {
            border-radius: 20px;
            padding: 16px;
            min-height: 132px;
            border: 1px solid var(--line);
            background: linear-gradient(180deg, #fff 0%, #f8f2ea 100%);
        }

        .desk.free {
            border-style: dashed;
            background: linear-gradient(180deg, #fefbf7 0%, #f3ecdf 100%);
        }

        label {
            display: grid;
            gap: 6px;
            font-size: 0.95rem;
        }

        input, select, button {
            font: inherit;
            border-radius: 14px;
            border: 1px solid var(--line);
            padding: 12px 14px;
            background: #fff;
        }

        button {
            cursor: pointer;
            background: var(--accent);
            color: #fff8f2;
            border: none;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .ghost {
            background: #f1e5d7;
            color: var(--accent-deep);
        }

        .row {
            display: grid;
            gap: 12px;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            padding: 14px;
            border-radius: 16px;
            border: 1px solid var(--line);
            background: #fff;
        }

        .flash {
            padding: 14px 16px;
            border-radius: 16px;
        }

        .flash.success { background: rgba(47, 107, 79, 0.12); color: var(--success); }
        .flash.error { background: rgba(159, 45, 45, 0.12); color: var(--danger); }

        .muted { color: var(--muted); }

        @media (max-width: 1024px) {
            .hero,
            .content,
            .week {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .stats,
            .room-grid,
            .row {
                grid-template-columns: 1fr;
            }

            .page {
                width: min(100% - 20px, 1240px);
                padding-top: 20px;
            }

            .tab button {
                min-width: 100%;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <div class="shell">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <section class="panel">
                <div class="eyebrow">DeskFlow / aktywny profil</div>
                <div class="tabs" aria-label="Zakladki uzytkownikow">
                    {% for user in users %}
                        {% set tabStatus = null %}
                        {% for status in userStatuses %}
                            {% if status.id == user.id %}
                                {% set tabStatus = status %}
                            {% endif %}
                        {% endfor %}
                        <form class="tab" method="post" action="{{ path('app_active_user') }}">
                            <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                            <input type="hidden" name="userId" value="{{ user.id }}">
                            <button type="submit" class="{% if activeUser and activeUser.id == user.id %}active{% endif %}">
                                <strong>{{ user.name }}</strong>
                                <span>{{ user.team }}</span>
                                <small>
                                    {% if tabStatus and tabStatus.isOnVacation %}
                                        Dzisiaj urlop
                                    {% elseif tabStatus and tabStatus.deskLabel %}
                                        Biurko dzisiaj: {{ tabStatus.deskLabel }}
                                    {% else %}
                                        Dzisiaj bez biurka
                                    {% endif %}
                                </small>
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </section>

            <section class="hero">
                <article class="panel">
                    <div class="eyebrow">Profil dnia</div>
                    <h1>{{ activeUser.name }}</h1>
                    <p class="muted">
                        {% if activeUserStatus.isOnVacation %}
                            Dzisiaj jest na urlopie i nie zajmuje biurka.
                        {% elseif activeUserStatus.deskLabel %}
                            Dzisiaj zajmuje biurko {{ activeUserStatus.deskLabel }}.
                        {% else %}
                            Dzisiaj nie ma zajetego biurka.
                        {% endif %}
                    </p>
                    <p class="lead">
                        Widok skupia sie na jednym aktywnym uzytkowniku. Widzisz jego dzisiejszy status, stale biurko,
                        plan obecnosci i akcje, ktore mozesz wykonac bez przelaczania sie na widok calej listy osob.
                    </p>

                    <div class="chip-row">
                        <span class="chip">Zespol: {{ activeUser.team }}</span>
                        <span class="chip">Data operacyjna: {{ selectedDate|date('d.m.Y') }}</span>
                        <span class="chip">Przypisane biurko: {{ activeUserStatus.assignedDeskLabel }}</span>
                        <span class="chip">Urlop: {{ activeUserStatus.vacationDaysRemaining }}/{{ activeUserStatus.vacationDaysTotal }} dni</span>
                    </div>

                    <div class="stats">
                        <div class="stat">
                            <strong>{{ activeUserStatus.deskLabel ?: 'brak' }}</strong>
                            <span>Biurko na wybrany dzien</span>
                        </div>
                        <div class="stat">
                            <strong>{{ activeUserStatus.statusLabel }}</strong>
                            <span>Status aktywnego uzytkownika</span>
                        </div>
                        <div class="stat">
                            <strong>{{ availableDesks|length }}</strong>
                            <span>Wolne biurka do przejecia</span>
                        </div>
                    </div>
                </article>

                <aside class="panel stack">
                    <div>
                        <h2>Zakladka: dzien pracy</h2>
                        <p class="muted">Zmien date albo wykonaj akcje dla aktywnego uzytkownika.</p>
                    </div>

                    <form method="get" action="{{ path('app_dashboard') }}">
                        <label>
                            Dzien roboczy
                            <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                        </label>
                        <button class="ghost" type="submit">Pokaz plan dnia</button>
                    </form>

                    <div class="meta-list">
                        <div class="meta-item">
                            <strong>Harmonogram tygodnia</strong>
                            <div class="muted">{{ activeUserStatus.schedule|join(', ') }}</div>
                        </div>
                        <div class="meta-item">
                            <strong>Pozostaly limit urlopu</strong>
                            <div class="muted">{{ activeUserStatus.vacationDaysRemaining }} z {{ activeUserStatus.vacationDaysTotal }} dni</div>
                        </div>
                        <div class="meta-item">
                            <strong>Status na wybrany dzien</strong>
                            <span class="pill {% if activeUserStatus.isOnVacation %}vacation{% elseif activeUserStatus.deskLabel and activeUserStatus.isScheduledToday %}schedule{% elseif activeUserStatus.deskLabel %}claim{% else %}none{% endif %}">
                                {% if activeUserStatus.deskLabel %}
                                    {{ activeUserStatus.deskLabel }}
                                {% elseif activeUserStatus.isOnVacation %}
                                    na urlopie
                                {% else %}
                                    brak miejsca
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </aside>
            </section>

            <section class="panel">
                <div class="eyebrow">Zakladka: tydzien</div>
                <h2>Perspektywa 5 dni</h2>
                <div class="week">
                    {% for day in weekOverview %}
                        <div class="week-day">
                            <strong>{{ day.date|date('D, d.m') }}</strong>
                            <p class="muted">{{ day.occupiedCount }} zajetych / {{ day.freeCount }} wolnych</p>
                            <span class="pill vacation">{{ day.vacationCount }} urlop</span>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section class="content">
                <div class="stack">
                    <article class="panel">
                        <div class="eyebrow">Zakladka: biurka</div>
                        <h2>Plan pomieszczen</h2>
                        <div class="rooms">
                            {% for room in rooms %}
                                <article>
                                    <h3>{{ room.name }}</h3>
                                    <p class="muted">{{ room.description }}</p>
                                    <div class="room-grid">
                                        {% for desk in room.desks %}
                                            <div class="desk {% if desk.isFree %}free{% endif %}">
                                                <strong>{{ desk.label }}</strong>
                                                {% if desk.occupancy %}
                                                    <p>{{ desk.occupancy.userName }}</p>
                                                    <p class="muted">{{ desk.occupancy.team }}</p>
                                                    <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                {% else %}
                                                    <p>Biurko wolne</p>
                                                    <span class="pill none">mozna zajac</span>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    </article>
                </div>

                <div class="stack">
                    <article class="panel">
                        <div class="eyebrow">Zakladka: akcje</div>
                        <h2>Wniosek urlopowy</h2>
                        <form method="post" action="{{ path('app_vacation_request') }}">
                            <input type="hidden" name="userId" value="{{ activeUser.id }}">
                            <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                            <label>
                                Start urlopu
                                <input type="date" name="startDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                            </label>
                            <label>
                                Koniec urlopu
                                <input type="date" name="endDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                            </label>
                            <button type="submit">Zapisz urlop</button>
                        </form>
                    </article>

                    <article class="panel">
                        <div class="eyebrow">Zakladka: akcje</div>
                        <h2>Przypisz biurko na ten dzien</h2>
                        {% if activeUserStatus.isOnVacation %}
                            <p class="muted">Uzytkownik jest na urlopie, dlatego nie mozna przypisac mu biurka.</p>
                        {% elseif activeUserStatus.deskLabel %}
                            <p class="muted">To biurko jest juz zajete przez aktywnego uzytkownika w wybranym dniu.</p>
                            <div class="meta-item">
                                <strong>Aktualnie zajete biurko</strong>
                                <div class="muted">{{ activeUserStatus.deskLabel }} / {{ activeUserStatus.statusLabel }}</div>
                            </div>
                        {% else %}
                            <p class="muted">Uzytkownik nie ma przypisanego biurka na wybrany dzien, wiec mozesz przypisac mu jedno z wolnych miejsc.</p>
                            <form method="post" action="{{ path('app_desk_claim') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    Wolne biurko
                                    <select name="deskId" required>
                                        {% for desk in availableDesks %}
                                            <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                        {% else %}
                                            <option value="">Brak wolnych biurek</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <button type="submit" {% if availableDesks is empty %}disabled{% endif %}>Przypisz i zajmij biurko</button>
                            </form>
                        {% endif %}
                    </article>

                    <article class="panel">
                        <div class="eyebrow">Zakladka: historia</div>
                        <h2>Historia aktywnego uzytkownika</h2>

                        <h3>Zaplanowane urlopy</h3>
                        <div class="table-like">
                            {% for vacation in vacations %}
                                <div class="row">
                                    <div>
                                        <strong>{{ vacation.userName }}</strong>
                                        <div class="muted">Urlop zapisany</div>
                                    </div>
                                    <div>{{ vacation.startDate }}</div>
                                    <div>{{ vacation.endDate }}</div>
                                </div>
                            {% else %}
                                <p class="muted">Brak wnioskow urlopowych dla aktywnego uzytkownika.</p>
                            {% endfor %}
                        </div>

                        <h3 style="margin-top: 20px;">Zajecia wolnych biurek</h3>
                        <div class="table-like">
                            {% for claim in deskClaims %}
                                <div class="row">
                                    <div>
                                        <strong>{{ claim.userName }}</strong>
                                        <div class="muted">Przejete dodatkowe miejsce</div>
                                    </div>
                                    <div>{{ claim.deskLabel }}</div>
                                    <div>{{ claim.date }}</div>
                                </div>
                            {% else %}
                                <p class="muted">Brak dodatkowych zajec biurek dla aktywnego uzytkownika.</p>
                            {% endfor %}
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
