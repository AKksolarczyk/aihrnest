{% extends 'base.html.twig' %}

{% block title %}DeskFlow{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --bg: #071120;
            --bg-soft: #0d1b31;
            --surface: rgba(10, 24, 45, 0.74);
            --surface-strong: rgba(16, 35, 62, 0.9);
            --surface-alt: rgba(12, 28, 50, 0.62);
            --card: rgba(247, 250, 255, 0.94);
            --card-strong: #ffffff;
            --ink: #0f172a;
            --ink-soft: #d9e8ff;
            --muted: #88a0c5;
            --line: rgba(140, 181, 255, 0.2);
            --line-strong: rgba(140, 181, 255, 0.32);
            --accent: #2f7cf6;
            --accent-strong: #1d4ed8;
            --accent-soft: rgba(47, 124, 246, 0.14);
            --cyan: #53c7ff;
            --success: #15b79e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --shadow: 0 28px 80px rgba(3, 11, 26, 0.38);
            --shadow-soft: 0 18px 48px rgba(6, 16, 35, 0.22);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--ink-soft);
            background:
                radial-gradient(circle at top left, rgba(83, 199, 255, 0.22), transparent 24%),
                radial-gradient(circle at 85% 12%, rgba(47, 124, 246, 0.28), transparent 26%),
                linear-gradient(160deg, #071120 0%, #0c1730 48%, #112447 100%);
            min-height: 100vh;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 85%);
            opacity: 0.45;
        }

        h1, h2, h3, p { margin-top: 0; }

        h1, h2, h3 {
            letter-spacing: -0.03em;
        }

        h1 {
            font-size: clamp(2.5rem, 4vw, 4.1rem);
            line-height: 0.95;
            margin-bottom: 16px;
            max-width: 10ch;
        }

        h2 {
            font-size: 1.45rem;
            margin-bottom: 10px;
            color: var(--ink);
        }

        h3 {
            font-size: 1.05rem;
            margin-bottom: 8px;
            color: var(--ink);
        }

        .page {
            width: min(1240px, calc(100% - 32px));
            margin: 0 auto;
            padding: 28px 0 56px;
        }

        .shell {
            display: grid;
            gap: 24px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 16px 20px;
            border-radius: 24px;
            border: 1px solid rgba(140, 181, 255, 0.18);
            background: linear-gradient(180deg, rgba(10, 24, 45, 0.82) 0%, rgba(17, 36, 71, 0.76) 100%);
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(18px);
        }

        .topbar-user {
            display: grid;
            gap: 4px;
        }

        .topbar-label {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--cyan);
            font-size: 0.72rem;
            font-weight: 800;
        }

        .topbar strong {
            font-size: 1.05rem;
            color: #ffffff;
        }

        .topbar-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 18px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
            transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
        }

        .topbar-link:hover {
            transform: translateY(-1px);
        }

        .panel {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(241, 247, 255, 0.92) 100%);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 28px;
            padding: 26px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(18px);
            color: var(--ink);
            position: relative;
            overflow: hidden;
        }

        .panel::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(47, 124, 246, 0.08), transparent 45%, rgba(83, 199, 255, 0.08));
            pointer-events: none;
        }

        .tabs {
            display: grid;
            gap: 12px;
            margin-bottom: 6px;
            max-height: 40vh;
            overflow-y: auto;
            padding-right: 8px;
            align-content: start;
            scrollbar-width: thin;
            scrollbar-color: rgba(47, 124, 246, 0.55) rgba(47, 124, 246, 0.08);
        }

        .user-search {
            display: grid;
            gap: 10px;
            margin: 18px 0 16px;
        }

        .user-search-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            font-size: 0.82rem;
            color: #5b7297;
            font-weight: 700;
        }

        .user-search-empty {
            display: none;
            padding: 14px 16px;
            border-radius: 18px;
            border: 1px dashed rgba(47, 124, 246, 0.22);
            background: rgba(47, 124, 246, 0.06);
            color: #47628c;
            font-size: 0.92rem;
        }

        .user-search-empty.visible {
            display: block;
        }

        .tabs::-webkit-scrollbar {
            width: 10px;
        }

        .tabs::-webkit-scrollbar-track {
            background: rgba(47, 124, 246, 0.08);
            border-radius: 999px;
        }

        .tabs::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #2f7cf6 0%, #53c7ff 100%);
            border-radius: 999px;
            border: 2px solid rgba(241, 247, 255, 0.9);
        }

        .tab {
            margin: 0;
        }

        .tab.is-hidden {
            display: none;
        }

        .tab button {
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.78);
            color: var(--ink);
            border-radius: 22px;
            padding: 14px 18px;
            cursor: pointer;
            min-width: 180px;
            text-align: left;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
            transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background 160ms ease;
        }

        .tab button:hover {
            transform: translateY(-2px);
            border-color: rgba(47, 124, 246, 0.26);
            box-shadow: 0 14px 28px rgba(47, 124, 246, 0.12);
        }

        .tab button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 58%, #53c7ff 100%);
            color: #eff6ff;
            border-color: transparent;
            box-shadow: 0 22px 36px rgba(29, 78, 216, 0.3);
        }

        .tab strong,
        .tab span {
            display: block;
        }

        .tab span {
            font-size: 0.85rem;
            opacity: 0.78;
            margin-top: 4px;
        }

        .tab small {
            display: block;
            font-size: 0.78rem;
            margin-top: 8px;
            opacity: 0.9;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--accent);
            font-size: 12px;
            margin-bottom: 12px;
            font-weight: 800;
        }

        .lead {
            font-size: 1.04rem;
            line-height: 1.72;
            max-width: 58ch;
            color: #31456a;
        }

        .chip-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 22px;
        }

        .chip,
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border-radius: 999px;
            font-size: 0.84rem;
            border: 1px solid rgba(47, 124, 246, 0.14);
            font-weight: 700;
        }

        .chip {
            background: rgba(255, 255, 255, 0.78);
            color: #23406f;
        }

        .pill {
            background: rgba(47, 124, 246, 0.1);
            color: #2155bf;
        }

        .pill.schedule { color: #1d4ed8; background: rgba(29, 78, 216, 0.12); }
        .pill.claim { color: #0f8b78; background: rgba(21, 183, 158, 0.14); }
        .pill.vacation { color: #b66a00; background: rgba(245, 158, 11, 0.16); }
        .pill.none { color: #5d7397; background: rgba(136, 160, 197, 0.16); }

        .stats {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            margin-top: 24px;
        }

        .stat {
            padding: 18px;
            border-radius: 22px;
            background: linear-gradient(180deg, rgba(10, 24, 45, 0.94) 0%, rgba(17, 36, 71, 0.92) 100%);
            border: 1px solid rgba(140, 181, 255, 0.12);
            color: var(--ink-soft);
            box-shadow: var(--shadow-soft);
        }

        .stat strong {
            display: block;
            font-size: 1.85rem;
            margin-bottom: 6px;
            color: #ffffff;
        }

        .stack,
        .table-like,
        form {
            display: grid;
            gap: 14px;
        }

        .meta-list,
        .week {
            display: grid;
            gap: 12px;
        }

        .meta-item {
            padding: 16px 18px;
            border-radius: 20px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.78);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
        }

        .meta-item strong,
        .week-day strong {
            display: block;
            margin-bottom: 4px;
        }

        .dashboard-layout {
            display: grid;
            gap: 20px;
            grid-template-columns: minmax(320px, 380px) minmax(0, 1fr);
            align-items: start;
        }

        .sidebar-column,
        .main-column {
            display: grid;
            gap: 20px;
        }

        .content {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.15fr 0.85fr;
        }

        .week {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .week-day {
            border: 1px solid rgba(47, 124, 246, 0.12);
            border-radius: 22px;
            padding: 16px;
            background: rgba(255, 255, 255, 0.84);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
        }

        .rooms {
            display: grid;
            gap: 18px;
        }

        .desk-view-toggle {
            display: inline-grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            padding: 6px;
            margin: 16px 0 20px;
            border-radius: 18px;
            background: rgba(47, 124, 246, 0.08);
            border: 1px solid rgba(47, 124, 246, 0.12);
        }

        .desk-view-button {
            min-width: 140px;
            padding: 10px 16px;
            border-radius: 14px;
            text-align: center;
            cursor: pointer;
            color: #27426f;
            font-size: 0.9rem;
            font-weight: 800;
            transition: background 160ms ease, color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
            border: none;
            background: transparent;
            box-shadow: none;
        }

        .desk-view-button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
        }

        .room-views {
            display: grid;
            gap: 18px;
        }

        .room-view {
            display: none;
        }

        .room-view.active {
            display: block;
        }

        .room-grid {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            margin-top: 16px;
        }

        .desk {
            border-radius: 22px;
            padding: 18px;
            min-height: 132px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 247, 255, 0.88) 100%);
            box-shadow: var(--shadow-soft);
        }

        .desk form {
            margin-top: 12px;
        }

        .desk-action {
            width: 100%;
            padding: 10px 14px;
            border-radius: 14px;
            font-size: 0.9rem;
            line-height: 1.3;
        }

        .desk.free {
            border-style: dashed;
            background: linear-gradient(180deg, rgba(240, 249, 255, 0.95) 0%, rgba(226, 240, 255, 0.88) 100%);
        }

        .desk-map {
            position: relative;
            margin-top: 16px;
            min-height: 280px;
            padding: 22px;
            border-radius: 28px;
            border: 1px solid rgba(47, 124, 246, 0.14);
            background:
                linear-gradient(180deg, rgba(246, 250, 255, 0.98) 0%, rgba(232, 243, 255, 0.92) 100%);
            overflow: auto;
        }

        .desk-map::before {
            content: "";
            position: absolute;
            inset: 18px;
            border-radius: 22px;
            border: 1px dashed rgba(47, 124, 246, 0.16);
            background:
                linear-gradient(rgba(47, 124, 246, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(47, 124, 246, 0.05) 1px, transparent 1px);
            background-size: 56px 56px;
            pointer-events: none;
        }

        .desk-map-room {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 16px;
            align-items: stretch;
        }

        .desk-map-item {
            min-height: 124px;
            display: grid;
            align-content: start;
        }

        .desk-map-item .desk {
            height: 100%;
            min-height: 124px;
        }

        .map-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 16px;
        }

        .map-legend span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            color: #4b6288;
            font-weight: 700;
        }

        .map-dot {
            width: 12px;
            height: 12px;
            border-radius: 999px;
            display: inline-block;
        }

        .map-dot.free {
            background: #53c7ff;
        }

        .map-dot.busy {
            background: #1d4ed8;
        }

        label {
            display: grid;
            gap: 6px;
            font-size: 0.95rem;
            color: #27426f;
            font-weight: 700;
        }

        input, select, button {
            font: inherit;
            border-radius: 16px;
            border: 1px solid rgba(47, 124, 246, 0.14);
            padding: 13px 15px;
            background: rgba(255, 255, 255, 0.95);
        }

        input,
        select {
            color: var(--ink);
            box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
        }

        input:focus,
        select:focus,
        button:focus {
            outline: 2px solid rgba(47, 124, 246, 0.22);
            outline-offset: 2px;
        }

        button {
            cursor: pointer;
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            border: none;
            font-weight: 800;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
            transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
        }

        button:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 22px 34px rgba(29, 78, 216, 0.28);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .ghost {
            background: rgba(47, 124, 246, 0.1);
            color: var(--accent-strong);
            box-shadow: none;
            border: 1px solid rgba(47, 124, 246, 0.14);
        }

        .row {
            display: grid;
            gap: 12px;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            padding: 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .admin-desk-grid {
            display: grid;
            gap: 14px;
        }

        .content-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 18px;
        }

        .content-tab-button {
            border: 1px solid rgba(47, 124, 246, 0.14);
            background: rgba(255, 255, 255, 0.86);
            color: var(--ink);
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 800;
            box-shadow: none;
        }

        .content-tab-button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            border-color: transparent;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
        }

        .content-tab-panel {
            display: none;
        }

        .content-tab-panel.active {
            display: block;
        }

        .admin-desk-form {
            display: grid;
            gap: 12px;
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr) auto;
            align-items: end;
            padding: 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .admin-desk-form strong,
        .admin-desk-form span {
            display: block;
        }

        .admin-desk-form span {
            margin-top: 4px;
            color: #5b7297;
            font-size: 0.9rem;
        }

        .flash {
            padding: 15px 18px;
            border-radius: 18px;
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: var(--shadow-soft);
        }

        .flash.success { background: rgba(21, 183, 158, 0.14); color: #d7fff6; }
        .flash.error { background: rgba(239, 68, 68, 0.16); color: #ffe7e7; }

        .muted { color: var(--muted); }

        .sidebar-column > .panel:first-child {
            background:
                linear-gradient(180deg, rgba(10, 24, 45, 0.9) 0%, rgba(17, 36, 71, 0.88) 100%);
            color: var(--ink-soft);
            border-color: rgba(140, 181, 255, 0.14);
        }

        .sidebar-column > .panel:first-child h2,
        .sidebar-column > .panel:first-child h3,
        .sidebar-column > .panel:first-child label {
            color: #f8fbff;
        }

        .sidebar-column > .panel:first-child .meta-item,
        .sidebar-column > .panel:first-child input,
        .sidebar-column > .panel:first-child select {
            background: rgba(255, 255, 255, 0.08);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.16);
        }

        .sidebar-column > .panel:first-child .muted {
            color: #b7cbed;
        }

        .sidebar-column > .panel:first-child .ghost {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.18);
        }

        @media (max-width: 1024px) {
            .dashboard-layout,
            .content,
            .week {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                align-items: start;
                flex-direction: column;
            }

            .topbar-actions {
                width: 100%;
            }

            .stats,
            .room-grid,
            .row,
            .admin-desk-form {
                grid-template-columns: 1fr;
            }

            .page {
                width: min(100% - 20px, 1240px);
                padding-top: 20px;
            }

            .panel {
                border-radius: 24px;
                padding: 20px;
            }

            h1 {
                max-width: none;
            }

            .tab button {
                min-width: 100%;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <div class="shell">
            {% if app.user %}
                <section class="topbar" aria-label="Zalogowany uzytkownik">
                    <div class="topbar-user">
                        <span class="topbar-label">Zalogowano jako</span>
                        <strong>{{ app.user.name }}</strong>
                    </div>
                    <div class="topbar-actions">
                        <div class="topbar-meta">
                            <span class="chip">{{ app.user.email }}</span>
                            {% if app.user.team %}
                                <span class="chip">Zespol: {{ app.user.team }}</span>
                            {% endif %}
                        </div>
                        <a class="topbar-link ghost" href="{{ path('app_logout') }}">Wyloguj</a>
                    </div>
                </section>
            {% endif %}

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <section class="dashboard-layout">
                <div class="sidebar-column">
                    <aside class="panel stack">
                    <div>
                        <div class="eyebrow">DeskFlow / dzien pracy</div>
                        <h2>Dzien pracy</h2>
                    </div>

                    <form method="get" action="{{ path('app_dashboard') }}">
                        <label>
                            Dzien roboczy
                            <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}" onchange="this.form.submit()">
                        </label>
                    </form>

                    <div class="meta-list">
                        <div class="meta-item">
                            <strong>Aktywny uzytkownik</strong>
                            <div class="muted">{{ activeUser.name }}{% if activeUser.team %} / {{ activeUser.team }}{% endif %}</div>
                            <div class="muted">Rola: {{ activeUser.role == 'admin' ? 'Admin' : 'User' }}</div>
                        </div>
                    </div>
                    </aside>

                    <aside class="panel">
                        <div class="eyebrow">DeskFlow / uzytkownicy</div>
                        <div class="user-search">
                            <label for="user-search-input">
                                Wyszukaj uzytkownika
                                <input
                                    id="user-search-input"
                                    type="search"
                                    placeholder="Imie, zespol, rola lub status"
                                    autocomplete="off"
                                    data-user-search-input
                                >
                            </label>
                            <div class="user-search-meta">
                                <span data-user-search-count>{{ users|length }} z {{ users|length }} uzytkownikow</span>
                            </div>
                        </div>
                        <div class="user-search-empty" data-user-search-empty>
                            Brak uzytkownikow pasujacych do wyszukiwania.
                        </div>
                        <div class="tabs" aria-label="Zakladki uzytkownikow" data-user-search-list>
                            {% for user in users %}
                                {% set tabStatus = null %}
                                {% for status in userStatuses %}
                                    {% if status.id == user.id %}
                                        {% set tabStatus = status %}
                                    {% endif %}
                                {% endfor %}
                                {% set statusText = tabStatus and tabStatus.isOnVacation
                                    ? 'Dzisiaj urlop'
                                    : (tabStatus and tabStatus.deskLabel ? 'Biurko dzisiaj: ' ~ tabStatus.deskLabel : 'Dzisiaj bez biurka')
                                %}
                                <form
                                    class="tab"
                                    method="post"
                                    action="{{ path('app_active_user') }}"
                                    data-user-search-item
                                    data-user-search-text="{{ (user.name ~ ' ' ~ user.team ~ ' ' ~ (user.role == 'admin' ? 'admin' : 'user') ~ ' ' ~ statusText)|lower }}"
                                >
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <input type="hidden" name="userId" value="{{ user.id }}">
                                    <button type="submit" class="{% if activeUser and activeUser.id == user.id %}active{% endif %}">
                                        <strong>{{ user.name }}</strong>
                                        <span>{{ user.team }}</span>
                                        <span>Rola: {{ user.role == 'admin' ? 'Admin' : 'User' }}</span>
                                        <small>
                                            {{ statusText }}
                                        </small>
                                    </button>
                                </form>
                            {% endfor %}
                        </div>
                    </aside>

                    <div class="stack">
                        <article class="panel">
                            <div class="eyebrow">Zakladka: akcje</div>
                            <h2>Wniosek urlopowy</h2>
                            <form method="post" action="{{ path('app_vacation_request') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    Start urlopu
                                    <input type="date" name="startDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <label>
                                    Koniec urlopu
                                    <input type="date" name="endDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <button type="submit">Zapisz urlop</button>
                            </form>
                        </article>

                        <article class="panel">
                            <div class="eyebrow">Zakladka: akcje</div>
                            <h2>Przypisz biurko na ten dzien</h2>
                            {% if activeUserStatus.isOnVacation %}
                                <p class="muted">Uzytkownik jest na urlopie, dlatego nie mozna przypisac mu biurka.</p>
                            {% elseif activeUserStatus.deskLabel %}
                                <p class="muted">To biurko jest juz zajete przez aktywnego uzytkownika w wybranym dniu.</p>
                                <div class="meta-item">
                                    <strong>Aktualnie zajete biurko</strong>
                                    <div class="muted">{{ activeUserStatus.deskLabel }} / {{ activeUserStatus.statusLabel }}</div>
                                </div>
                            {% else %}
                                <p class="muted">Uzytkownik nie ma przypisanego biurka na wybrany dzien, wiec mozesz przypisac mu jedno z wolnych miejsc.</p>
                                <form method="post" action="{{ path('app_desk_claim') }}">
                                    <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <label>
                                        Wolne biurko
                                        <select name="deskId" required>
                                            {% for desk in availableDesks %}
                                                <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                            {% else %}
                                                <option value="">Brak wolnych biurek</option>
                                            {% endfor %}
                                        </select>
                                    </label>
                                    <button type="submit" {% if availableDesks is empty %}disabled{% endif %}>Przypisz i zajmij biurko</button>
                                </form>
                            {% endif %}
                        </article>

                        <article class="panel">
                            <div class="eyebrow">Zakladka: historia</div>
                            <h2>Historia aktywnego uzytkownika</h2>

                            <h3>Zaplanowane urlopy</h3>
                            <div class="table-like">
                                {% for vacation in vacations %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ vacation.userName }}</strong>
                                            <div class="muted">Urlop zapisany</div>
                                        </div>
                                        <div>{{ vacation.startDate }}</div>
                                        <div>{{ vacation.endDate }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">Brak wnioskow urlopowych dla aktywnego uzytkownika.</p>
                                {% endfor %}
                            </div>

                            <h3 style="margin-top: 20px;">Zajecia wolnych biurek</h3>
                            <div class="table-like">
                                {% for claim in deskClaims %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ claim.userName }}</strong>
                                            <div class="muted">Przejete dodatkowe miejsce</div>
                                        </div>
                                        <div>{{ claim.deskLabel }}</div>
                                        <div>{{ claim.date }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">Brak dodatkowych zajec biurek dla aktywnego uzytkownika.</p>
                                {% endfor %}
                            </div>
                        </article>
                    </div>
                </div>

                <div class="main-column">
                    <div class="content-tabs" aria-label="Glowne zakladki widoku">
                        <button type="button" class="content-tab-button active" data-content-tab-target="desks">Biurka</button>
                        <button type="button" class="content-tab-button" data-content-tab-target="week">Tydzien</button>
                        {% if is_granted('ROLE_ADMIN') %}
                            <button type="button" class="content-tab-button" data-content-tab-target="admin-desks">Edycja biurek</button>
                        {% endif %}
                    </div>

                    <div class="content-tab-panel active" data-content-tab="desks">
                        <article class="panel">
                            <div class="eyebrow">Zakladka: biurka</div>
                            <h2>Plan pomieszczen</h2>
                            <div class="desk-view-toggle" aria-label="Przelacz widok biurek">
                                <button type="button" class="desk-view-button active" data-desk-view-target="cards">Widok kart</button>
                                <button type="button" class="desk-view-button" data-desk-view-target="map">Mapa 2D</button>
                            </div>

                            <div class="room-views">
                                <div class="room-view room-view-list active" data-desk-view="cards">
                                    <div class="rooms">
                                        {% for room in rooms %}
                                            <article>
                                                <h3>{{ room.name }}</h3>
                                                <p class="muted">{{ room.description }}</p>
                                                <div class="room-grid">
                                                    {% for desk in room.desks %}
                                                        <div class="desk {% if desk.isFree %}free{% endif %}">
                                                            <strong>{{ desk.label }}</strong>
                                                            {% if desk.occupancy %}
                                                                <p>{{ desk.occupancy.userName }}</p>
                                                                <p class="muted">{{ desk.occupancy.team }}</p>
                                                                <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                            {% else %}
                                                                <p>Biurko wolne</p>
                                                                {% if activeUserStatus.isOnVacation %}
                                                                    <button type="button" class="desk-action ghost" disabled>{{ activeUser.name }} jest na urlopie</button>
                                                                {% elseif activeUserStatus.deskLabel %}
                                                                    <button type="button" class="desk-action ghost" disabled>{{ activeUser.name }} ma juz biurko</button>
                                                                {% else %}
                                                                    <form method="post" action="{{ path('app_desk_claim') }}">
                                                                        <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                        <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                        <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                        <button type="submit" class="desk-action">Zajmij jako {{ activeUser.name }}</button>
                                                                    </form>
                                                                {% endif %}
                                                            {% endif %}
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            </article>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div class="room-view room-view-map" data-desk-view="map">
                                    <div class="rooms">
                                        {% for room in rooms %}
                                            <article>
                                                <h3>{{ room.name }}</h3>
                                                <p class="muted">{{ room.description }}</p>
                                                <div class="desk-map">
                                                    <div
                                                        class="desk-map-room"
                                                        style="grid-template-columns: repeat({{ room.map.width }}, minmax(72px, 1fr)); grid-template-rows: repeat({{ room.map.height }}, minmax(56px, auto));"
                                                    >
                                                        {% for desk in room.desks %}
                                                            <div
                                                                class="desk-map-item"
                                                                style="grid-column: {{ desk.position.x }} / span 1; grid-row: {{ desk.position.y }} / span 1;"
                                                            >
                                                                <div class="desk {% if desk.isFree %}free{% endif %}">
                                                                    <strong>{{ desk.label }}</strong>
                                                                    {% if desk.occupancy %}
                                                                        <p>{{ desk.occupancy.userName }}</p>
                                                                        <p class="muted">{{ desk.occupancy.team }}</p>
                                                                        <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                                    {% else %}
                                                                        <p>Biurko wolne</p>
                                                                        {% if activeUserStatus.isOnVacation %}
                                                                            <button type="button" class="desk-action ghost" disabled>{{ activeUser.name }} jest na urlopie</button>
                                                                        {% elseif activeUserStatus.deskLabel %}
                                                                            <button type="button" class="desk-action ghost" disabled>{{ activeUser.name }} ma juz biurko</button>
                                                                        {% else %}
                                                                            <form method="post" action="{{ path('app_desk_claim') }}">
                                                                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                                <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                                <button type="submit" class="desk-action">Zajmij jako {{ activeUser.name }}</button>
                                                                            </form>
                                                                        {% endif %}
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                    <div class="map-legend" aria-hidden="true">
                                                        <span><i class="map-dot free"></i> Wolne biurko</span>
                                                        <span><i class="map-dot busy"></i> Zajete biurko</span>
                                                    </div>
                                                </div>
                                            </article>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>

                    <div class="content-tab-panel" data-content-tab="week">
                        <article class="panel">
                            <div class="eyebrow">Zakladka: tydzien</div>
                            <h2>Perspektywa 5 dni</h2>
                            <div class="week">
                                {% for day in weekOverview %}
                                    <div class="week-day">
                                        <strong>{{ day.date|date('D, d.m') }}</strong>
                                        <p class="muted">{{ day.occupiedCount }} zajetych / {{ day.freeCount }} wolnych</p>
                                        <span class="pill vacation">{{ day.vacationCount }} urlop</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </article>
                    </div>

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="content-tab-panel" data-content-tab="admin-desks">
                            <article class="panel">
                                <div class="eyebrow">Admin / biurka</div>
                                <h2>Modyfikowanie nazw biurek</h2>
                                <p class="lead">Ten widok jest dostepny tylko dla administratora i pozwala zmieniac nazwy wyswietlane w planie pomieszczen oraz przy rezerwacjach. Mozesz wpisac kilka zmian naraz i zapisac je jednym przyciskiem albo klawiszem Enter.</p>

                                <form method="post" action="{{ path('app_admin_desk_label_update') }}">
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <input type="hidden" name="activeUserId" value="{{ activeUser.id }}">
                                    <input type="hidden" name="tab" value="admin-desks">

                                    <div class="admin-desk-grid">
                                        {% for room in rooms %}
                                            {% for desk in room.desks %}
                                                <div class="admin-desk-form">
                                                    <div>
                                                        <strong>{{ desk.id }}</strong>
                                                        <span>{{ room.name }}</span>
                                                    </div>
                                                    <label>
                                                        Nazwa biurka
                                                        <input type="text" name="labels[{{ desk.id }}]" value="{{ desk.label }}" maxlength="255" required>
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        {% endfor %}
                                    </div>

                                    <div style="margin-top: 20px;">
                                        <button type="submit">Zapisz wszystkie nazwy</button>
                                    </div>
                                </form>
                            </article>
                        </div>
                    {% endif %}
                </div>
            </section>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = Array.from(document.querySelectorAll('[data-desk-view-target]'));
            const views = Array.from(document.querySelectorAll('[data-desk-view]'));
            const contentTabButtons = Array.from(document.querySelectorAll('[data-content-tab-target]'));
            const contentTabPanels = Array.from(document.querySelectorAll('[data-content-tab]'));
            const userSearchInput = document.querySelector('[data-user-search-input]');
            const userSearchItems = Array.from(document.querySelectorAll('[data-user-search-item]'));
            const userSearchCount = document.querySelector('[data-user-search-count]');
            const userSearchEmpty = document.querySelector('[data-user-search-empty]');
            const url = new URL(window.location.href);
            const initialContentTab = url.searchParams.get('tab');

            function activateContentTab(target) {
                if (!target) {
                    return;
                }

                contentTabButtons.forEach(function (item) {
                    item.classList.toggle('active', item.getAttribute('data-content-tab-target') === target);
                });

                contentTabPanels.forEach(function (panel) {
                    panel.classList.toggle('active', panel.getAttribute('data-content-tab') === target);
                });
            }

            function normalizeSearchText(value) {
                return (value || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '');
            }

            function updateUserSearch() {
                if (!userSearchInput || userSearchItems.length === 0) {
                    return;
                }

                const phrase = normalizeSearchText(userSearchInput.value);
                let visibleCount = 0;

                userSearchItems.forEach(function (item) {
                    const haystack = normalizeSearchText(item.getAttribute('data-user-search-text'));
                    const matches = phrase === '' || haystack.includes(phrase);

                    item.classList.toggle('is-hidden', !matches);

                    if (matches) {
                        visibleCount += 1;
                    }
                });

                if (userSearchCount) {
                    userSearchCount.textContent = visibleCount + ' z ' + userSearchItems.length + ' uzytkownikow';
                }

                if (userSearchEmpty) {
                    userSearchEmpty.classList.toggle('visible', visibleCount === 0);
                }
            }

            buttons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const target = button.getAttribute('data-desk-view-target');

                    buttons.forEach(function (item) {
                        item.classList.toggle('active', item === button);
                    });

                    views.forEach(function (view) {
                        view.classList.toggle('active', view.getAttribute('data-desk-view') === target);
                    });
                });
            });

            contentTabButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    activateContentTab(button.getAttribute('data-content-tab-target'));
                });
            });

            if (userSearchInput) {
                userSearchInput.addEventListener('input', updateUserSearch);
                updateUserSearch();
            }

            activateContentTab(initialContentTab);
        });
    </script>
{% endblock %}
