{% extends 'base.html.twig' %}

{% block title %}DeskFlow{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --bg: #071120;
            --bg-soft: #0d1b31;
            --surface: rgba(10, 24, 45, 0.74);
            --surface-strong: rgba(16, 35, 62, 0.9);
            --surface-alt: rgba(12, 28, 50, 0.62);
            --card: rgba(247, 250, 255, 0.94);
            --card-strong: #ffffff;
            --ink: #0f172a;
            --ink-soft: #d9e8ff;
            --muted: #88a0c5;
            --line: rgba(140, 181, 255, 0.2);
            --line-strong: rgba(140, 181, 255, 0.32);
            --accent: #2f7cf6;
            --accent-strong: #1d4ed8;
            --accent-soft: rgba(47, 124, 246, 0.14);
            --cyan: #53c7ff;
            --success: #15b79e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --shadow: 0 28px 80px rgba(3, 11, 26, 0.38);
            --shadow-soft: 0 18px 48px rgba(6, 16, 35, 0.22);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--ink-soft);
            background:
                radial-gradient(circle at top left, rgba(83, 199, 255, 0.22), transparent 24%),
                radial-gradient(circle at 85% 12%, rgba(47, 124, 246, 0.28), transparent 26%),
                linear-gradient(160deg, #071120 0%, #0c1730 48%, #112447 100%);
            min-height: 100vh;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 85%);
            opacity: 0.45;
        }

        h1, h2, h3, p { margin-top: 0; }

        h1, h2, h3 {
            letter-spacing: -0.03em;
        }

        h1 {
            font-size: clamp(2.5rem, 4vw, 4.1rem);
            line-height: 0.95;
            margin-bottom: 16px;
            max-width: 10ch;
        }

        h2 {
            font-size: 1.45rem;
            margin-bottom: 10px;
            color: var(--ink);
        }

        h3 {
            font-size: 1.05rem;
            margin-bottom: 8px;
            color: var(--ink);
        }

        .page {
            width: min(1240px, calc(100% - 32px));
            margin: 0 auto;
            padding: 28px 0 56px;
        }

        .shell {
            display: grid;
            gap: 24px;
        }

        .panel {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(241, 247, 255, 0.92) 100%);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 28px;
            padding: 26px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(18px);
            color: var(--ink);
            position: relative;
            overflow: hidden;
        }

        .panel::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(47, 124, 246, 0.08), transparent 45%, rgba(83, 199, 255, 0.08));
            pointer-events: none;
        }

        .tabs {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 6px;
        }

        .tab {
            margin: 0;
        }

        .tab button {
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.78);
            color: var(--ink);
            border-radius: 22px;
            padding: 14px 18px;
            cursor: pointer;
            min-width: 180px;
            text-align: left;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
            transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background 160ms ease;
        }

        .tab button:hover {
            transform: translateY(-2px);
            border-color: rgba(47, 124, 246, 0.26);
            box-shadow: 0 14px 28px rgba(47, 124, 246, 0.12);
        }

        .tab button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 58%, #53c7ff 100%);
            color: #eff6ff;
            border-color: transparent;
            box-shadow: 0 22px 36px rgba(29, 78, 216, 0.3);
        }

        .tab strong,
        .tab span {
            display: block;
        }

        .tab span {
            font-size: 0.85rem;
            opacity: 0.78;
            margin-top: 4px;
        }

        .tab small {
            display: block;
            font-size: 0.78rem;
            margin-top: 8px;
            opacity: 0.9;
        }

        .hero {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.45fr 0.95fr;
            align-items: stretch;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--accent);
            font-size: 12px;
            margin-bottom: 12px;
            font-weight: 800;
        }

        .lead {
            font-size: 1.04rem;
            line-height: 1.72;
            max-width: 58ch;
            color: #31456a;
        }

        .chip-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 22px;
        }

        .chip,
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border-radius: 999px;
            font-size: 0.84rem;
            border: 1px solid rgba(47, 124, 246, 0.14);
            font-weight: 700;
        }

        .chip {
            background: rgba(255, 255, 255, 0.78);
            color: #23406f;
        }

        .pill {
            background: rgba(47, 124, 246, 0.1);
            color: #2155bf;
        }

        .pill.schedule { color: #1d4ed8; background: rgba(29, 78, 216, 0.12); }
        .pill.claim { color: #0f8b78; background: rgba(21, 183, 158, 0.14); }
        .pill.vacation { color: #b66a00; background: rgba(245, 158, 11, 0.16); }
        .pill.none { color: #5d7397; background: rgba(136, 160, 197, 0.16); }

        .stats {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            margin-top: 24px;
        }

        .stat {
            padding: 18px;
            border-radius: 22px;
            background: linear-gradient(180deg, rgba(10, 24, 45, 0.94) 0%, rgba(17, 36, 71, 0.92) 100%);
            border: 1px solid rgba(140, 181, 255, 0.12);
            color: var(--ink-soft);
            box-shadow: var(--shadow-soft);
        }

        .stat strong {
            display: block;
            font-size: 1.85rem;
            margin-bottom: 6px;
            color: #ffffff;
        }

        .stack,
        .table-like,
        form {
            display: grid;
            gap: 14px;
        }

        .meta-list,
        .week {
            display: grid;
            gap: 12px;
        }

        .meta-item {
            padding: 16px 18px;
            border-radius: 20px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.78);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
        }

        .meta-item strong,
        .week-day strong {
            display: block;
            margin-bottom: 4px;
        }

        .content {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.15fr 0.85fr;
        }

        .week {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .week-day {
            border: 1px solid rgba(47, 124, 246, 0.12);
            border-radius: 22px;
            padding: 16px;
            background: rgba(255, 255, 255, 0.84);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
        }

        .rooms {
            display: grid;
            gap: 18px;
        }

        .room-grid {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            margin-top: 16px;
        }

        .desk {
            border-radius: 22px;
            padding: 18px;
            min-height: 132px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 247, 255, 0.88) 100%);
            box-shadow: var(--shadow-soft);
        }

        .desk.free {
            border-style: dashed;
            background: linear-gradient(180deg, rgba(240, 249, 255, 0.95) 0%, rgba(226, 240, 255, 0.88) 100%);
        }

        label {
            display: grid;
            gap: 6px;
            font-size: 0.95rem;
            color: #27426f;
            font-weight: 700;
        }

        input, select, button {
            font: inherit;
            border-radius: 16px;
            border: 1px solid rgba(47, 124, 246, 0.14);
            padding: 13px 15px;
            background: rgba(255, 255, 255, 0.95);
        }

        input,
        select {
            color: var(--ink);
            box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
        }

        input:focus,
        select:focus,
        button:focus {
            outline: 2px solid rgba(47, 124, 246, 0.22);
            outline-offset: 2px;
        }

        button {
            cursor: pointer;
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            border: none;
            font-weight: 800;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
            transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
        }

        button:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 22px 34px rgba(29, 78, 216, 0.28);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .ghost {
            background: rgba(47, 124, 246, 0.1);
            color: var(--accent-strong);
            box-shadow: none;
            border: 1px solid rgba(47, 124, 246, 0.14);
        }

        .row {
            display: grid;
            gap: 12px;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            padding: 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .flash {
            padding: 15px 18px;
            border-radius: 18px;
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: var(--shadow-soft);
        }

        .flash.success { background: rgba(21, 183, 158, 0.14); color: #d7fff6; }
        .flash.error { background: rgba(239, 68, 68, 0.16); color: #ffe7e7; }

        .muted { color: var(--muted); }

        .shell > .hero .panel:first-child {
            background:
                radial-gradient(circle at top right, rgba(83, 199, 255, 0.2), transparent 34%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(239, 247, 255, 0.94) 100%);
        }

        .shell > .hero .panel:last-child {
            background:
                linear-gradient(180deg, rgba(10, 24, 45, 0.9) 0%, rgba(17, 36, 71, 0.88) 100%);
            color: var(--ink-soft);
            border-color: rgba(140, 181, 255, 0.14);
        }

        .shell > .hero .panel:last-child h2,
        .shell > .hero .panel:last-child h3,
        .shell > .hero .panel:last-child label {
            color: #f8fbff;
        }

        .shell > .hero .panel:last-child .meta-item,
        .shell > .hero .panel:last-child input,
        .shell > .hero .panel:last-child select {
            background: rgba(255, 255, 255, 0.08);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.16);
        }

        .shell > .hero .panel:last-child .muted {
            color: #b7cbed;
        }

        .shell > .hero .panel:last-child .ghost {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.18);
        }

        @media (max-width: 1024px) {
            .hero,
            .content,
            .week {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .stats,
            .room-grid,
            .row {
                grid-template-columns: 1fr;
            }

            .page {
                width: min(100% - 20px, 1240px);
                padding-top: 20px;
            }

            .panel {
                border-radius: 24px;
                padding: 20px;
            }

            h1 {
                max-width: none;
            }

            .tab button {
                min-width: 100%;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <div class="shell">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <section class="panel">
                <div class="eyebrow">DeskFlow / aktywny profil</div>
                <div class="tabs" aria-label="Zakladki uzytkownikow">
                    {% for user in users %}
                        {% set tabStatus = null %}
                        {% for status in userStatuses %}
                            {% if status.id == user.id %}
                                {% set tabStatus = status %}
                            {% endif %}
                        {% endfor %}
                        <form class="tab" method="post" action="{{ path('app_active_user') }}">
                            <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                            <input type="hidden" name="userId" value="{{ user.id }}">
                            <button type="submit" class="{% if activeUser and activeUser.id == user.id %}active{% endif %}">
                                <strong>{{ user.name }}</strong>
                                <span>{{ user.team }}</span>
                                <small>
                                    {% if tabStatus and tabStatus.isOnVacation %}
                                        Dzisiaj urlop
                                    {% elseif tabStatus and tabStatus.deskLabel %}
                                        Biurko dzisiaj: {{ tabStatus.deskLabel }}
                                    {% else %}
                                        Dzisiaj bez biurka
                                    {% endif %}
                                </small>
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </section>

            <section class="hero">
                <article class="panel">
                    <div class="eyebrow">Profil dnia</div>
                    <h1>{{ activeUser.name }}</h1>
                    <p class="muted">
                        {% if activeUserStatus.isOnVacation %}
                            Dzisiaj jest na urlopie i nie zajmuje biurka.
                        {% elseif activeUserStatus.deskLabel %}
                            Dzisiaj zajmuje biurko {{ activeUserStatus.deskLabel }}.
                        {% else %}
                            Dzisiaj nie ma zajetego biurka.
                        {% endif %}
                    </p>
                    <p class="lead">
                        Widok skupia sie na jednym aktywnym uzytkowniku. Widzisz jego dzisiejszy status, stale biurko,
                        plan obecnosci i akcje, ktore mozesz wykonac bez przelaczania sie na widok calej listy osob.
                    </p>

                    <div class="chip-row">
                        <span class="chip">Zespol: {{ activeUser.team }}</span>
                        <span class="chip">Data operacyjna: {{ selectedDate|date('d.m.Y') }}</span>
                        <span class="chip">Przypisane biurko: {{ activeUserStatus.assignedDeskLabel }}</span>
                        <span class="chip">Urlop: {{ activeUserStatus.vacationDaysRemaining }}/{{ activeUserStatus.vacationDaysTotal }} dni</span>
                    </div>

                    <div class="stats">
                        <div class="stat">
                            <strong>{{ activeUserStatus.deskLabel ?: 'brak' }}</strong>
                            <span>Biurko na wybrany dzien</span>
                        </div>
                        <div class="stat">
                            <strong>{{ activeUserStatus.statusLabel }}</strong>
                            <span>Status aktywnego uzytkownika</span>
                        </div>
                        <div class="stat">
                            <strong>{{ availableDesks|length }}</strong>
                            <span>Wolne biurka do przejecia</span>
                        </div>
                    </div>
                </article>

                <aside class="panel stack">
                    <div>
                        <h2>Zakladka: dzien pracy</h2>
                        <p class="muted">Zmien date albo wykonaj akcje dla aktywnego uzytkownika.</p>
                    </div>

                    <form method="get" action="{{ path('app_dashboard') }}">
                        <label>
                            Dzien roboczy
                            <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                        </label>
                        <button class="ghost" type="submit">Pokaz plan dnia</button>
                    </form>

                    <div class="meta-list">
                        <div class="meta-item">
                            <strong>Harmonogram tygodnia</strong>
                            <div class="muted">{{ activeUserStatus.schedule|join(', ') }}</div>
                        </div>
                        <div class="meta-item">
                            <strong>Pozostaly limit urlopu</strong>
                            <div class="muted">{{ activeUserStatus.vacationDaysRemaining }} z {{ activeUserStatus.vacationDaysTotal }} dni</div>
                        </div>
                        <div class="meta-item">
                            <strong>Status na wybrany dzien</strong>
                            <span class="pill {% if activeUserStatus.isOnVacation %}vacation{% elseif activeUserStatus.deskLabel and activeUserStatus.isScheduledToday %}schedule{% elseif activeUserStatus.deskLabel %}claim{% else %}none{% endif %}">
                                {% if activeUserStatus.deskLabel %}
                                    {{ activeUserStatus.deskLabel }}
                                {% elseif activeUserStatus.isOnVacation %}
                                    na urlopie
                                {% else %}
                                    brak miejsca
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </aside>
            </section>

            <section class="panel">
                <div class="eyebrow">Zakladka: tydzien</div>
                <h2>Perspektywa 5 dni</h2>
                <div class="week">
                    {% for day in weekOverview %}
                        <div class="week-day">
                            <strong>{{ day.date|date('D, d.m') }}</strong>
                            <p class="muted">{{ day.occupiedCount }} zajetych / {{ day.freeCount }} wolnych</p>
                            <span class="pill vacation">{{ day.vacationCount }} urlop</span>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section class="content">
                <div class="stack">
                    <article class="panel">
                        <div class="eyebrow">Zakladka: biurka</div>
                        <h2>Plan pomieszczen</h2>
                        <div class="rooms">
                            {% for room in rooms %}
                                <article>
                                    <h3>{{ room.name }}</h3>
                                    <p class="muted">{{ room.description }}</p>
                                    <div class="room-grid">
                                        {% for desk in room.desks %}
                                            <div class="desk {% if desk.isFree %}free{% endif %}">
                                                <strong>{{ desk.label }}</strong>
                                                {% if desk.occupancy %}
                                                    <p>{{ desk.occupancy.userName }}</p>
                                                    <p class="muted">{{ desk.occupancy.team }}</p>
                                                    <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                {% else %}
                                                    <p>Biurko wolne</p>
                                                    <span class="pill none">mozna zajac</span>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    </article>
                </div>

                <div class="stack">
                    <article class="panel">
                        <div class="eyebrow">Zakladka: akcje</div>
                        <h2>Wniosek urlopowy</h2>
                        <form method="post" action="{{ path('app_vacation_request') }}">
                            <input type="hidden" name="userId" value="{{ activeUser.id }}">
                            <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                            <label>
                                Start urlopu
                                <input type="date" name="startDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                            </label>
                            <label>
                                Koniec urlopu
                                <input type="date" name="endDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                            </label>
                            <button type="submit">Zapisz urlop</button>
                        </form>
                    </article>

                    <article class="panel">
                        <div class="eyebrow">Zakladka: akcje</div>
                        <h2>Przypisz biurko na ten dzien</h2>
                        {% if activeUserStatus.isOnVacation %}
                            <p class="muted">Uzytkownik jest na urlopie, dlatego nie mozna przypisac mu biurka.</p>
                        {% elseif activeUserStatus.deskLabel %}
                            <p class="muted">To biurko jest juz zajete przez aktywnego uzytkownika w wybranym dniu.</p>
                            <div class="meta-item">
                                <strong>Aktualnie zajete biurko</strong>
                                <div class="muted">{{ activeUserStatus.deskLabel }} / {{ activeUserStatus.statusLabel }}</div>
                            </div>
                        {% else %}
                            <p class="muted">Uzytkownik nie ma przypisanego biurka na wybrany dzien, wiec mozesz przypisac mu jedno z wolnych miejsc.</p>
                            <form method="post" action="{{ path('app_desk_claim') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    Wolne biurko
                                    <select name="deskId" required>
                                        {% for desk in availableDesks %}
                                            <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                        {% else %}
                                            <option value="">Brak wolnych biurek</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <button type="submit" {% if availableDesks is empty %}disabled{% endif %}>Przypisz i zajmij biurko</button>
                            </form>
                        {% endif %}
                    </article>

                    <article class="panel">
                        <div class="eyebrow">Zakladka: historia</div>
                        <h2>Historia aktywnego uzytkownika</h2>

                        <h3>Zaplanowane urlopy</h3>
                        <div class="table-like">
                            {% for vacation in vacations %}
                                <div class="row">
                                    <div>
                                        <strong>{{ vacation.userName }}</strong>
                                        <div class="muted">Urlop zapisany</div>
                                    </div>
                                    <div>{{ vacation.startDate }}</div>
                                    <div>{{ vacation.endDate }}</div>
                                </div>
                            {% else %}
                                <p class="muted">Brak wnioskow urlopowych dla aktywnego uzytkownika.</p>
                            {% endfor %}
                        </div>

                        <h3 style="margin-top: 20px;">Zajecia wolnych biurek</h3>
                        <div class="table-like">
                            {% for claim in deskClaims %}
                                <div class="row">
                                    <div>
                                        <strong>{{ claim.userName }}</strong>
                                        <div class="muted">Przejete dodatkowe miejsce</div>
                                    </div>
                                    <div>{{ claim.deskLabel }}</div>
                                    <div>{{ claim.date }}</div>
                                </div>
                            {% else %}
                                <p class="muted">Brak dodatkowych zajec biurek dla aktywnego uzytkownika.</p>
                            {% endfor %}
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </div>
{% endblock %}
