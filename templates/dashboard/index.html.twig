{% extends 'base.html.twig' %}

{% block title %}DeskFlow{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --bg: #f8fbff;
            --bg-soft: #e0ebff;
            --surface: rgba(255, 255, 255, 0.86);
            --surface-strong: rgba(255, 255, 255, 0.96);
            --surface-alt: rgba(235, 242, 255, 0.92);
            --card: rgba(255, 255, 255, 0.98);
            --card-strong: #ffffff;
            --ink: #0f172a;
            --ink-soft: #1f3251;
            --muted: #5f728f;
            --line: rgba(15, 23, 42, 0.09);
            --line-strong: rgba(15, 23, 42, 0.16);
            --accent: #2f7cf6;
            --accent-strong: #1d4ed8;
            --accent-soft: rgba(47, 124, 246, 0.14);
            --cyan: #53c7ff;
            --success: #15b79e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --shadow: 0 28px 80px rgba(59, 87, 138, 0.16);
            --shadow-soft: 0 18px 48px rgba(59, 87, 138, 0.1);
            --page-glow-a: rgba(132, 204, 255, 0.2);
            --page-glow-b: rgba(82, 141, 255, 0.16);
            --page-bg-gradient: linear-gradient(160deg, #ffffff 0%, #f4f8ff 46%, #dde9ff 100%);
            --grid-line: rgba(15, 23, 42, 0.045);
            --panel-bg: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(242, 247, 255, 0.96) 100%);
            --panel-border: rgba(15, 23, 42, 0.08);
            --panel-overlay: linear-gradient(135deg, rgba(47, 124, 246, 0.07), transparent 45%, rgba(83, 199, 255, 0.06));
            --stat-bg: linear-gradient(180deg, rgba(229, 238, 255, 0.96) 0%, rgba(214, 228, 255, 0.96) 100%);
            --stat-border: rgba(47, 124, 246, 0.12);
            --stat-value: #0f172a;
            --control-bg: rgba(255, 255, 255, 0.88);
            --control-border: rgba(47, 124, 246, 0.14);
            --control-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84);
            --desk-bg: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(241, 246, 255, 0.94) 100%);
            --desk-free-bg: linear-gradient(180deg, rgba(243, 249, 255, 0.98) 0%, rgba(228, 239, 255, 0.94) 100%);
            --map-bg: linear-gradient(180deg, rgba(250, 252, 255, 0.98) 0%, rgba(233, 242, 255, 0.94) 100%);
            --map-grid-line: rgba(47, 124, 246, 0.06);
            --soft-text: #456181;
        }

        :root[data-theme="dark"] {
            --bg: #020712;
            --bg-soft: #081222;
            --surface: rgba(5, 12, 24, 0.84);
            --surface-strong: rgba(9, 18, 34, 0.94);
            --surface-alt: rgba(10, 21, 39, 0.8);
            --card: rgba(11, 19, 35, 0.96);
            --card-strong: #111c31;
            --ink: #e5eefc;
            --ink-soft: #d9e8ff;
            --muted: #88a0c5;
            --line: rgba(140, 181, 255, 0.2);
            --line-strong: rgba(140, 181, 255, 0.32);
            --accent: #2f7cf6;
            --accent-strong: #1d4ed8;
            --accent-soft: rgba(47, 124, 246, 0.14);
            --cyan: #53c7ff;
            --success: #15b79e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --shadow: 0 28px 80px rgba(1, 4, 12, 0.58);
            --shadow-soft: 0 18px 48px rgba(1, 4, 12, 0.36);
            --page-glow-a: rgba(18, 66, 123, 0.34);
            --page-glow-b: rgba(29, 78, 216, 0.28);
            --page-bg-gradient: linear-gradient(160deg, #020712 0%, #08111f 48%, #0c1930 100%);
            --grid-line: rgba(255, 255, 255, 0.025);
            --panel-bg: linear-gradient(180deg, rgba(7, 15, 28, 0.96) 0%, rgba(11, 21, 39, 0.94) 100%);
            --panel-border: rgba(140, 181, 255, 0.12);
            --panel-overlay: linear-gradient(135deg, rgba(47, 124, 246, 0.12), transparent 45%, rgba(83, 199, 255, 0.08));
            --stat-bg: linear-gradient(180deg, rgba(12, 26, 48, 0.96) 0%, rgba(15, 34, 62, 0.94) 100%);
            --stat-border: rgba(140, 181, 255, 0.14);
            --stat-value: #ffffff;
            --control-bg: rgba(255, 255, 255, 0.06);
            --control-border: rgba(140, 181, 255, 0.14);
            --control-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
            --desk-bg: linear-gradient(180deg, rgba(10, 21, 39, 0.98) 0%, rgba(13, 27, 48, 0.94) 100%);
            --desk-free-bg: linear-gradient(180deg, rgba(11, 28, 48, 0.96) 0%, rgba(16, 36, 60, 0.94) 100%);
            --map-bg: linear-gradient(180deg, rgba(7, 16, 30, 0.98) 0%, rgba(10, 21, 39, 0.94) 100%);
            --map-grid-line: rgba(83, 199, 255, 0.07);
            --soft-text: #9bb2d7;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--ink-soft);
            background:
                radial-gradient(circle at top left, var(--page-glow-a), transparent 24%),
                radial-gradient(circle at 85% 12%, var(--page-glow-b), transparent 26%),
                var(--page-bg-gradient);
            min-height: 100vh;
            transition: background 180ms ease, color 180ms ease;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(var(--grid-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 85%);
            opacity: 0.45;
        }

        h1, h2, h3, p { margin-top: 0; }

        h1, h2, h3 {
            letter-spacing: -0.03em;
        }

        h1 {
            font-size: clamp(2.5rem, 4vw, 4.1rem);
            line-height: 0.95;
            margin-bottom: 16px;
            max-width: 10ch;
        }

        h2 {
            font-size: 1.45rem;
            margin-bottom: 10px;
            color: var(--ink);
        }

        h3 {
            font-size: 1.05rem;
            margin-bottom: 8px;
            color: var(--ink);
        }

        .page {
            width: min(1240px, calc(100% - 32px));
            margin: 0 auto;
            padding: 28px 0 56px;
        }

        .shell {
            display: grid;
            gap: 24px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 16px 20px;
            border-radius: 24px;
            border: 1px solid rgba(140, 181, 255, 0.18);
            background: linear-gradient(180deg, rgba(10, 24, 45, 0.82) 0%, rgba(17, 36, 71, 0.76) 100%);
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(18px);
        }

        .topbar-user {
            display: grid;
            gap: 4px;
        }

        .topbar-label {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--cyan);
            font-size: 0.72rem;
            font-weight: 800;
        }

        .topbar strong {
            font-size: 1.05rem;
            color: #ffffff;
        }

        .topbar-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 18px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
            transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
        }

        .topbar-link:hover {
            transform: translateY(-1px);
        }

        .panel {
            background: var(--panel-bg);
            border: 1px solid var(--panel-border);
            border-radius: 28px;
            padding: 26px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(18px);
            color: var(--ink);
            position: relative;
            overflow: hidden;
        }

        .panel::after {
            content: "";
            position: absolute;
            inset: 0;
            background: var(--panel-overlay);
            pointer-events: none;
        }

        .tabs {
            display: grid;
            gap: 12px;
            margin-bottom: 6px;
            max-height: 40vh;
            overflow-y: auto;
            padding-right: 8px;
            align-content: start;
            scrollbar-width: thin;
            scrollbar-color: rgba(47, 124, 246, 0.55) rgba(47, 124, 246, 0.08);
        }

        .user-search {
            display: grid;
            gap: 10px;
            margin: 18px 0 16px;
        }

        .user-search-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            font-size: 0.82rem;
            color: #5b7297;
            font-weight: 700;
        }

        .user-search-empty {
            display: none;
            padding: 14px 16px;
            border-radius: 18px;
            border: 1px dashed rgba(47, 124, 246, 0.22);
            background: rgba(47, 124, 246, 0.06);
            color: #47628c;
            font-size: 0.92rem;
        }

        .user-search-empty.visible {
            display: block;
        }

        .tabs::-webkit-scrollbar {
            width: 10px;
        }

        .tabs::-webkit-scrollbar-track {
            background: rgba(47, 124, 246, 0.08);
            border-radius: 999px;
        }

        .tabs::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #2f7cf6 0%, #53c7ff 100%);
            border-radius: 999px;
            border: 2px solid rgba(241, 247, 255, 0.9);
        }

        .tab {
            margin: 0;
        }

        .tab.is-hidden {
            display: none;
        }

        .tab button {
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.78);
            color: var(--ink);
            border-radius: 22px;
            padding: 14px 18px;
            cursor: pointer;
            min-width: 180px;
            text-align: left;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
            transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease, background 160ms ease;
        }

        .tab button:hover {
            transform: translateY(-2px);
            border-color: rgba(47, 124, 246, 0.26);
            box-shadow: 0 14px 28px rgba(47, 124, 246, 0.12);
        }

        .tab button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 58%, #53c7ff 100%);
            color: #eff6ff;
            border-color: transparent;
            box-shadow: 0 22px 36px rgba(29, 78, 216, 0.3);
        }

        .tab strong,
        .tab span {
            display: block;
        }

        .tab span {
            font-size: 0.85rem;
            opacity: 0.78;
            margin-top: 4px;
        }

        .tab small {
            display: block;
            font-size: 0.78rem;
            margin-top: 8px;
            opacity: 0.9;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--accent);
            font-size: 12px;
            margin-bottom: 12px;
            font-weight: 800;
        }

        .lead {
            font-size: 1.04rem;
            line-height: 1.72;
            max-width: 58ch;
            color: var(--soft-text);
        }

        .chip-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 22px;
        }

        .chip,
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border-radius: 999px;
            font-size: 0.84rem;
            border: 1px solid var(--control-border);
            font-weight: 700;
        }

        .chip {
            background: var(--control-bg);
            color: var(--ink-soft);
        }

        .pill {
            background: rgba(47, 124, 246, 0.1);
            color: #2155bf;
        }

        .pill.schedule { color: #1d4ed8; background: rgba(29, 78, 216, 0.12); }
        .pill.claim { color: #0f8b78; background: rgba(21, 183, 158, 0.14); }
        .pill.vacation { color: #b66a00; background: rgba(245, 158, 11, 0.16); }
        .pill.none { color: #5d7397; background: rgba(136, 160, 197, 0.16); }

        .stats {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            margin-top: 24px;
        }

        .stat {
            padding: 18px;
            border-radius: 22px;
            background: var(--stat-bg);
            border: 1px solid var(--stat-border);
            color: var(--ink-soft);
            box-shadow: var(--shadow-soft);
        }

        .stat strong {
            display: block;
            font-size: 1.85rem;
            margin-bottom: 6px;
            color: var(--stat-value);
        }

        .stack,
        .table-like,
        form {
            display: grid;
            gap: 14px;
        }

        .meta-list,
        .week {
            display: grid;
            gap: 12px;
        }

        .meta-item {
            padding: 16px 18px;
            border-radius: 20px;
            border: 1px solid var(--control-border);
            background: var(--control-bg);
            box-shadow: var(--control-shadow);
        }

        .meta-item strong,
        .week-day strong {
            display: block;
            margin-bottom: 4px;
        }

        .dashboard-layout {
            display: grid;
            gap: 20px;
            grid-template-columns: minmax(320px, 380px) minmax(0, 1fr);
            align-items: start;
        }

        .sidebar-column,
        .main-column {
            display: grid;
            gap: 20px;
        }

        .content {
            display: grid;
            gap: 20px;
            grid-template-columns: 1.15fr 0.85fr;
        }

        .week {
            grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .week-day {
            border: 1px solid var(--control-border);
            border-radius: 22px;
            padding: 16px;
            background: var(--control-bg);
            box-shadow: var(--control-shadow);
        }

        .rooms {
            display: grid;
            gap: 18px;
        }

        .desk-view-toggle {
            display: inline-grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            padding: 6px;
            margin: 16px 0 20px;
            border-radius: 18px;
            background: var(--surface-alt);
            border: 1px solid var(--control-border);
        }

        .desk-view-button {
            min-width: 140px;
            padding: 10px 16px;
            border-radius: 14px;
            text-align: center;
            cursor: pointer;
            color: var(--ink-soft);
            font-size: 0.9rem;
            font-weight: 800;
            transition: background 160ms ease, color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
            border: none;
            background: transparent;
            box-shadow: none;
        }

        .desk-view-button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
        }

        .room-views {
            display: grid;
            gap: 18px;
        }

        .room-view {
            display: none;
        }

        .room-view.active {
            display: block;
        }

        .room-grid {
            display: grid;
            gap: 14px;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            margin-top: 16px;
        }

        .desk {
            border-radius: 22px;
            padding: 18px;
            min-height: 132px;
            border: 1px solid var(--control-border);
            background: var(--desk-bg);
            box-shadow: var(--shadow-soft);
        }

        .desk form {
            margin-top: 12px;
        }

        .desk-action {
            width: 100%;
            padding: 10px 14px;
            border-radius: 14px;
            font-size: 0.9rem;
            line-height: 1.3;
        }

        .desk.free {
            border-style: dashed;
            background: var(--desk-free-bg);
        }

        .desk-map {
            position: relative;
            margin-top: 16px;
            min-height: 280px;
            padding: 22px;
            border-radius: 28px;
            border: 1px solid var(--control-border);
            background: var(--map-bg);
            overflow: auto;
        }

        .desk-map::before {
            content: "";
            position: absolute;
            inset: 18px;
            border-radius: 22px;
            border: 1px dashed var(--control-border);
            background:
                linear-gradient(var(--map-grid-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--map-grid-line) 1px, transparent 1px);
            background-size: 56px 56px;
            pointer-events: none;
        }

        .desk-map-room {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 16px;
            align-items: stretch;
        }

        .desk-map-item {
            min-height: 124px;
            display: grid;
            align-content: start;
        }

        .desk-map-item .desk {
            height: 100%;
            min-height: 124px;
        }

        .map-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 16px;
        }

        .map-legend span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            color: var(--soft-text);
            font-weight: 700;
        }

        .map-dot {
            width: 12px;
            height: 12px;
            border-radius: 999px;
            display: inline-block;
        }

        .map-dot.free {
            background: #53c7ff;
        }

        .map-dot.busy {
            background: #1d4ed8;
        }

        label {
            display: grid;
            gap: 6px;
            font-size: 0.95rem;
            color: var(--ink-soft);
            font-weight: 700;
        }

        input, select, button {
            font: inherit;
            border-radius: 16px;
            border: 1px solid rgba(47, 124, 246, 0.14);
            padding: 13px 15px;
            background: rgba(255, 255, 255, 0.95);
        }

        input,
        select {
            color: var(--ink);
            box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
        }

        input:focus,
        select:focus,
        button:focus {
            outline: 2px solid rgba(47, 124, 246, 0.22);
            outline-offset: 2px;
        }

        button {
            cursor: pointer;
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            border: none;
            font-weight: 800;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
            transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
        }

        button:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 22px 34px rgba(29, 78, 216, 0.28);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .ghost {
            background: rgba(47, 124, 246, 0.1);
            color: var(--accent-strong);
            box-shadow: none;
            border: 1px solid rgba(47, 124, 246, 0.14);
        }

        .row {
            display: grid;
            gap: 12px;
            grid-template-columns: 1fr auto auto;
            align-items: center;
            padding: 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .admin-desk-grid {
            display: grid;
            gap: 14px;
        }

        .content-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 18px;
        }

        .content-tab-button {
            border: 1px solid rgba(47, 124, 246, 0.14);
            background: rgba(255, 255, 255, 0.86);
            color: var(--ink);
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 800;
            box-shadow: none;
        }

        .content-tab-button.active {
            background: linear-gradient(135deg, #1d4ed8 0%, #2f7cf6 65%, #53c7ff 100%);
            color: #eff6ff;
            border-color: transparent;
            box-shadow: 0 18px 30px rgba(29, 78, 216, 0.22);
        }

        .content-tab-panel {
            display: none;
        }

        .content-tab-panel.active {
            display: block;
        }

        .finder-search,
        .report-grid,
        .report-list,
        .compact-list,
        .day-picker {
            display: grid;
            gap: 14px;
        }

        .report-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .report-card {
            padding: 18px;
            border-radius: 20px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .report-card strong {
            display: block;
            font-size: 1.8rem;
            margin-bottom: 6px;
        }

        .compact-item {
            padding: 14px 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .compact-item strong,
        .compact-item span {
            display: block;
        }

        .compact-item span {
            margin-top: 4px;
        }

        .people-list {
            display: grid;
            gap: 12px;
        }

        .people-card {
            padding: 18px;
            border-radius: 22px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.84);
        }

        .people-card.is-hidden {
            display: none;
        }

        .admin-desk-form {
            display: grid;
            gap: 12px;
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr) auto;
            align-items: end;
            padding: 16px;
            border-radius: 18px;
            border: 1px solid rgba(47, 124, 246, 0.12);
            background: rgba(255, 255, 255, 0.82);
        }

        .admin-desk-form strong,
        .admin-desk-form span {
            display: block;
        }

        .admin-desk-form span {
            margin-top: 4px;
            color: #5b7297;
            font-size: 0.9rem;
        }

        .flash {
            padding: 15px 18px;
            border-radius: 18px;
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: var(--shadow-soft);
        }

        .flash.success { background: rgba(21, 183, 158, 0.14); color: #d7fff6; }
        .flash.error { background: rgba(239, 68, 68, 0.16); color: #ffe7e7; }

        .muted { color: var(--muted); }

        .sidebar-column > .panel:first-child {
            background:
                linear-gradient(180deg, rgba(10, 24, 45, 0.9) 0%, rgba(17, 36, 71, 0.88) 100%);
            color: var(--ink-soft);
            border-color: rgba(140, 181, 255, 0.14);
        }

        .sidebar-column > .panel:first-child h2,
        .sidebar-column > .panel:first-child h3,
        .sidebar-column > .panel:first-child label {
            color: #f8fbff;
        }

        .sidebar-column > .panel:first-child .meta-item,
        .sidebar-column > .panel:first-child input,
        .sidebar-column > .panel:first-child select {
            background: rgba(255, 255, 255, 0.08);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.16);
        }

        .sidebar-column > .panel:first-child .muted {
            color: #b7cbed;
        }

        .sidebar-column > .panel:first-child .ghost {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fbff;
            border-color: rgba(140, 181, 255, 0.18);
        }

        @media (max-width: 1024px) {
            .dashboard-layout,
            .content,
            .week {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                align-items: start;
                flex-direction: column;
            }

            .topbar-actions {
                width: 100%;
            }

            .stats,
            .room-grid,
            .row,
            .admin-desk-form,
            .report-grid {
                grid-template-columns: 1fr;
            }

            .page {
                width: min(100% - 20px, 1240px);
                padding-top: 20px;
            }

            .panel {
                border-radius: 24px;
                padding: 20px;
            }

            h1 {
                max-width: none;
            }

            .tab button {
                min-width: 100%;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <div class="shell">
            {% if app.user %}
                <section class="topbar" aria-label="{{ 'dashboard.topbar.aria'|trans }}">
                    <div class="topbar-user">
                        <span class="topbar-label">{{ 'dashboard.topbar.logged_as'|trans }}</span>
                        <strong>{{ app.user.name }}</strong>
                    </div>
                    <div class="topbar-actions">
                        <div class="topbar-meta">
                            <span class="chip">{{ app.user.email }}</span>
                            {% if app.user.team %}
                                <span class="chip">{{ 'dashboard.topbar.team'|trans }}: {{ app.user.team }}</span>
                            {% endif %}
                        </div>
                        <a class="topbar-link ghost" href="{{ path('app_logout') }}">{{ 'dashboard.topbar.logout'|trans }}</a>
                    </div>
                </section>
            {% endif %}

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <section class="dashboard-layout">
                <div class="sidebar-column">
                    <aside class="panel stack">
                    <div>
                        <div class="eyebrow">{{ 'dashboard.sidebar.day.eyebrow'|trans }}</div>
                        <h2>{{ 'dashboard.sidebar.day.title'|trans }}</h2>
                    </div>

                    <form method="get" action="{{ path('app_dashboard') }}">
                        <label>
                            {{ 'dashboard.sidebar.day.label'|trans }}
                            <input type="date" name="date" value="{{ selectedDate|date('Y-m-d') }}" onchange="this.form.submit()">
                        </label>
                    </form>

                    <div class="meta-list">
                        <div class="meta-item">
                            <strong>{{ 'dashboard.sidebar.active_user'|trans }}</strong>
                            <div class="muted">{{ activeUser.name }}{% if activeUser.team %} / {{ activeUser.team }}{% endif %}</div>
                            <div class="muted">{{ 'dashboard.common.role'|trans }}: {{ ('dashboard.role.' ~ activeUser.role)|trans }}</div>
                        </div>
                    </div>
                    </aside>

                    <aside class="panel">
                        <div class="eyebrow">{{ 'dashboard.sidebar.users.eyebrow'|trans }}</div>
                        <div class="user-search">
                            <label for="user-search-input">
                                {{ 'dashboard.sidebar.users.search'|trans }}
                                <input
                                    id="user-search-input"
                                    type="search"
                                    placeholder="{{ 'dashboard.sidebar.users.search_placeholder'|trans }}"
                                    autocomplete="off"
                                    data-user-search-input
                                >
                            </label>
                            <div class="user-search-meta">
                                <span data-user-search-count>{{ 'dashboard.sidebar.users.count'|trans({'%visible%': users|length, '%total%': users|length}) }}</span>
                            </div>
                        </div>
                        <div class="user-search-empty" data-user-search-empty>
                            {{ 'dashboard.sidebar.users.empty'|trans }}
                        </div>
                        <div class="tabs" aria-label="{{ 'dashboard.sidebar.users.tabs_aria'|trans }}" data-user-search-list>
                            {% for user in users %}
                                {% set tabStatus = null %}
                                {% for status in userStatuses %}
                                    {% if status.id == user.id %}
                                        {% set tabStatus = status %}
                                    {% endif %}
                                {% endfor %}
                                {% set statusText = tabStatus and tabStatus.isOnVacation
                                    ? 'dashboard.sidebar.users.status.vacation'|trans
                                    : (tabStatus and tabStatus.deskLabel ? 'dashboard.sidebar.users.status.desk_today'|trans({'%desk%': tabStatus.deskLabel}) : 'dashboard.sidebar.users.status.no_desk_today'|trans)
                                %}
                                <form
                                    class="tab"
                                    method="post"
                                    action="{{ path('app_active_user') }}"
                                    data-user-search-item
                                    data-user-search-text="{{ (user.name ~ ' ' ~ user.team ~ ' ' ~ (user.role == 'admin' ? 'admin' : 'user') ~ ' ' ~ statusText)|lower }}"
                                >
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <input type="hidden" name="userId" value="{{ user.id }}">
                                    <button type="submit" class="{% if activeUser and activeUser.id == user.id %}active{% endif %}">
                                        <strong>{{ user.name }}</strong>
                                        <span>{{ user.team }}</span>
                                        <span>{{ 'dashboard.common.role'|trans }}: {{ ('dashboard.role.' ~ user.role)|trans }}</span>
                                        <small>
                                            {{ statusText }}
                                        </small>
                                    </button>
                                </form>
                            {% endfor %}
                        </div>
                    </aside>

                    <div class="stack">
                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.section.actions'|trans }}</div>
                            <h2>{{ 'dashboard.vacation.title'|trans }}</h2>
                            <form method="post" action="{{ path('app_vacation_request') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    {{ 'dashboard.vacation.start'|trans }}
                                    <input type="date" name="startDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <label>
                                    {{ 'dashboard.vacation.end'|trans }}
                                    <input type="date" name="endDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <button type="submit">{{ 'dashboard.vacation.submit'|trans }}</button>
                            </form>
                        </article>

                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.section.actions'|trans }}</div>
                            <h2>{{ 'dashboard.claim.title'|trans }}</h2>
                            {% if activeUserStatus.isOnVacation %}
                                <p class="muted">{{ 'dashboard.claim.on_vacation'|trans }}</p>
                            {% elseif activeUserStatus.deskLabel %}
                                <p class="muted">{{ 'dashboard.claim.already_has_desk'|trans }}</p>
                                <div class="meta-item">
                                    <strong>{{ 'dashboard.claim.current'|trans }}</strong>
                                    <div class="muted">{{ activeUserStatus.deskLabel }} / {{ activeUserStatus.statusLabel }}</div>
                                </div>
                                {% if activeUserStatus.occupancyType == 'claim' %}
                                    <form method="post" action="{{ path('app_desk_claim_release') }}">
                                        <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                        <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                        <button type="submit" class="ghost">{{ 'dashboard.claim.release'|trans }}</button>
                                    </form>
                                {% endif %}
                            {% else %}
                                <p class="muted">{{ 'dashboard.claim.help'|trans }}</p>
                                <form method="post" action="{{ path('app_desk_claim') }}">
                                    <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <label>
                                        {{ 'dashboard.claim.available_desk'|trans }}
                                        <select name="deskId" required>
                                            {% for desk in availableDesks %}
                                                <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                            {% else %}
                                                <option value="">{{ 'dashboard.claim.no_free_desks'|trans }}</option>
                                            {% endfor %}
                                        </select>
                                    </label>
                                    <button type="submit" {% if availableDesks is empty %}disabled{% endif %}>{{ 'dashboard.claim.submit'|trans }}</button>
                                </form>
                            {% endif %}
                        </article>

                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.section.actions'|trans }}</div>
                            <h2>{{ 'dashboard.recurring.title'|trans }}</h2>
                            <form method="post" action="{{ path('app_recurring_desk_claim_create') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    {{ 'dashboard.common.desk'|trans }}
                                    <select name="deskId" required>
                                        {% for desk in deskCatalog %}
                                            <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <div class="day-picker">
                                    <strong>{{ 'dashboard.recurring.weekdays'|trans }}</strong>
                                    {% for key in ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] %}
                                        <label class="checkbox">
                                            <input type="checkbox" name="weekdays[]" value="{{ key }}" {% if key in activeUserStatus.schedule %}checked{% endif %}>
                                            <span>{{ ('weekday.short.' ~ key)|trans }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                                <label>
                                    {{ 'common.from'|trans }}
                                    <input type="date" name="startDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <label>
                                    {{ 'common.to'|trans }}
                                    <input type="date" name="endDate" value="{{ selectedDate|date('Y-m-d') }}" required>
                                </label>
                                <button type="submit">{{ 'dashboard.recurring.submit'|trans }}</button>
                            </form>
                        </article>

                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.section.actions'|trans }}</div>
                            <h2>{{ 'dashboard.issue.title'|trans }}</h2>
                            <form method="post" action="{{ path('app_issue_report_create') }}">
                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                <label>
                                    {{ 'dashboard.issue.category'|trans }}
                                    <select name="category" required>
                                        <option value="sprzet">{{ 'dashboard.issue_category.sprzet'|trans }}</option>
                                        <option value="komfort">{{ 'dashboard.issue_category.komfort'|trans }}</option>
                                        <option value="siec">{{ 'dashboard.issue_category.siec'|trans }}</option>
                                        <option value="inne">{{ 'dashboard.issue_category.inne'|trans }}</option>
                                    </select>
                                </label>
                                <label>
                                    {{ 'dashboard.common.desk'|trans }}
                                    <select name="deskId">
                                        <option value="">{{ 'common.none'|trans }}</option>
                                        {% for desk in deskCatalog %}
                                            <option value="{{ desk.id }}">{{ desk.label }} / {{ desk.roomName }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <label>
                                    {{ 'dashboard.issue.room'|trans }}
                                    <select name="roomId">
                                        <option value="">{{ 'common.none'|trans }}</option>
                                        {% for room in roomCatalog %}
                                            <option value="{{ room.id }}">{{ room.name }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                                <label>
                                    {{ 'dashboard.issue.description'|trans }}
                                    <input type="text" name="description" maxlength="255" required>
                                </label>
                                <button type="submit">{{ 'dashboard.issue.submit'|trans }}</button>
                            </form>
                        </article>

                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.section.history'|trans }}</div>
                            <h2>{{ 'dashboard.history.title'|trans }}</h2>

                            <h3>{{ 'dashboard.history.vacations'|trans }}</h3>
                            <div class="table-like">
                                {% for vacation in vacations %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ vacation.userName }}</strong>
                                            <div class="muted">{{ 'dashboard.history.vacation_saved'|trans }}</div>
                                        </div>
                                        <div>{{ vacation.startDate }}</div>
                                        <div>{{ vacation.endDate }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.history.vacations_empty'|trans }}</p>
                                {% endfor %}
                            </div>

                            <h3 style="margin-top: 20px;">{{ 'dashboard.history.claims'|trans }}</h3>
                            <div class="table-like">
                                {% for claim in deskClaims %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ claim.userName }}</strong>
                                            <div class="muted">{{ 'dashboard.history.claim_saved'|trans }}</div>
                                        </div>
                                        <div>{{ claim.deskLabel }}</div>
                                        <div>{{ claim.date }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.history.claims_empty'|trans }}</p>
                                {% endfor %}
                            </div>

                            <h3 style="margin-top: 20px;">{{ 'dashboard.history.waitlist'|trans }}</h3>
                            <div class="table-like">
                                {% for entry in deskWaitlist %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ entry.deskLabel }}</strong>
                                            <div class="muted">{{ entry.roomName }}</div>
                                        </div>
                                        <div>{{ entry.date }}</div>
                                        <div>{{ ('dashboard.waitlist_status.' ~ entry.status)|trans }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.history.waitlist_empty'|trans }}</p>
                                {% endfor %}
                            </div>

                            <h3 style="margin-top: 20px;">{{ 'dashboard.history.recurring'|trans }}</h3>
                            <div class="table-like">
                                {% for reservation in recurringReservations %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ reservation.deskLabel }}</strong>
                                            <div class="muted">{{ reservation.roomName }} / {{ reservation.weekdays|map(day => ('weekday.short.' ~ day)|trans)|join(', ') }}</div>
                                        </div>
                                        <div>{{ reservation.startDate }}</div>
                                        <div>{{ reservation.endDate }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.history.recurring_empty'|trans }}</p>
                                {% endfor %}
                            </div>

                            <h3 style="margin-top: 20px;">{{ 'dashboard.history.issues'|trans }}</h3>
                            <div class="table-like">
                                {% for issue in issueReports %}
                                    <div class="row">
                                        <div>
                                            <strong>{{ ('dashboard.issue_category.' ~ issue.category)|trans }}</strong>
                                            <div class="muted">{{ issue.target }}</div>
                                        </div>
                                        <div>{{ ('dashboard.issue_status.' ~ issue.status)|trans }}</div>
                                        <div>{{ issue.reportedAt }}</div>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.history.issues_empty'|trans }}</p>
                                {% endfor %}
                            </div>
                        </article>
                    </div>
                </div>

                <div class="main-column">
                    <div class="content-tabs" aria-label="{{ 'dashboard.tabs.aria'|trans }}">
                        <button type="button" class="content-tab-button active" data-content-tab-target="desks">{{ 'dashboard.tabs.desks'|trans }}</button>
                        <button type="button" class="content-tab-button" data-content-tab-target="week">{{ 'dashboard.tabs.week'|trans }}</button>
                        <button type="button" class="content-tab-button" data-content-tab-target="people">{{ 'dashboard.tabs.people'|trans }}</button>
                        {% if is_granted('ROLE_ADMIN') %}
                            <button type="button" class="content-tab-button" data-content-tab-target="admin-desks">{{ 'dashboard.tabs.admin_desks'|trans }}</button>
                            <button type="button" class="content-tab-button" data-content-tab-target="admin-reports">{{ 'dashboard.tabs.admin_reports'|trans }}</button>
                        {% endif %}
                    </div>

                    <div class="content-tab-panel active" data-content-tab="desks">
                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.desks.eyebrow'|trans }}</div>
                            <h2>{{ 'dashboard.desks.title'|trans }}</h2>
                            <div class="desk-view-toggle" aria-label="{{ 'dashboard.desks.view_toggle'|trans }}">
                                <button type="button" class="desk-view-button active" data-desk-view-target="cards">{{ 'dashboard.desks.cards'|trans }}</button>
                                <button type="button" class="desk-view-button" data-desk-view-target="map">{{ 'dashboard.desks.map'|trans }}</button>
                            </div>

                            <div class="room-views">
                                <div class="room-view room-view-list active" data-desk-view="cards">
                                    <div class="rooms">
                                        {% for room in rooms %}
                                            <article>
                                                <h3>{{ room.name }}</h3>
                                                <p class="muted">{{ room.description }}</p>
                                                <div class="room-grid">
                                                    {% for desk in room.desks %}
                                                        <div class="desk {% if desk.isFree %}free{% endif %}">
                                                            <strong>{{ desk.label }}</strong>
                                                            {% if desk.occupancy %}
                                                                <p>{{ desk.occupancy.userName }}</p>
                                                                <p class="muted">{{ desk.occupancy.team }}</p>
                                                                <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                                {% if not activeUserStatus.isOnVacation and not activeUserStatus.deskLabel and activeUser.id != desk.occupancy.userId %}
                                                                    <form method="post" action="{{ path('app_desk_waitlist_join') }}">
                                                                        <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                        <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                        <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                        <button type="submit" class="desk-action ghost">{{ 'dashboard.desks.join_waitlist'|trans }}</button>
                                                                    </form>
                                                                {% endif %}
                                                            {% else %}
                                                                <p>{{ 'dashboard.desks.free'|trans }}</p>
                                                                {% if activeUserStatus.isOnVacation %}
                                                                    <button type="button" class="desk-action ghost" disabled>{{ 'dashboard.desks.user_on_vacation'|trans({'%name%': activeUser.name}) }}</button>
                                                                {% elseif activeUserStatus.deskLabel %}
                                                                    <button type="button" class="desk-action ghost" disabled>{{ 'dashboard.desks.user_has_desk'|trans({'%name%': activeUser.name}) }}</button>
                                                                {% else %}
                                                                    <form method="post" action="{{ path('app_desk_claim') }}">
                                                                        <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                        <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                        <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                        <button type="submit" class="desk-action">{{ 'dashboard.desks.claim_as'|trans({'%name%': activeUser.name}) }}</button>
                                                                    </form>
                                                                {% endif %}
                                                            {% endif %}
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            </article>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div class="room-view room-view-map" data-desk-view="map">
                                    <div class="rooms">
                                        {% for room in rooms %}
                                            <article>
                                                <h3>{{ room.name }}</h3>
                                                <p class="muted">{{ room.description }}</p>
                                                <div class="desk-map">
                                                    <div
                                                        class="desk-map-room"
                                                        style="grid-template-columns: repeat({{ room.map.width }}, minmax(72px, 1fr)); grid-template-rows: repeat({{ room.map.height }}, minmax(56px, auto));"
                                                    >
                                                        {% for desk in room.desks %}
                                                            <div
                                                                class="desk-map-item"
                                                                style="grid-column: {{ desk.position.x }} / span 1; grid-row: {{ desk.position.y }} / span 1;"
                                                            >
                                                                <div class="desk {% if desk.isFree %}free{% endif %}">
                                                                    <strong>{{ desk.label }}</strong>
                                                                    {% if desk.occupancy %}
                                                                        <p>{{ desk.occupancy.userName }}</p>
                                                                        <p class="muted">{{ desk.occupancy.team }}</p>
                                                                        <span class="pill {{ desk.occupancy.type }}">{{ desk.occupancy.label }}</span>
                                                                        {% if not activeUserStatus.isOnVacation and not activeUserStatus.deskLabel and activeUser.id != desk.occupancy.userId %}
                                                                            <form method="post" action="{{ path('app_desk_waitlist_join') }}">
                                                                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                                <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                                <button type="submit" class="desk-action ghost">{{ 'dashboard.desks.join_waitlist'|trans }}</button>
                                                                            </form>
                                                                        {% endif %}
                                                                    {% else %}
                                                                        <p>{{ 'dashboard.desks.free'|trans }}</p>
                                                                        {% if activeUserStatus.isOnVacation %}
                                                                            <button type="button" class="desk-action ghost" disabled>{{ 'dashboard.desks.user_on_vacation'|trans({'%name%': activeUser.name}) }}</button>
                                                                        {% elseif activeUserStatus.deskLabel %}
                                                                            <button type="button" class="desk-action ghost" disabled>{{ 'dashboard.desks.user_has_desk'|trans({'%name%': activeUser.name}) }}</button>
                                                                        {% else %}
                                                                            <form method="post" action="{{ path('app_desk_claim') }}">
                                                                                <input type="hidden" name="userId" value="{{ activeUser.id }}">
                                                                                <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                                                                <input type="hidden" name="deskId" value="{{ desk.id }}">
                                                                                <button type="submit" class="desk-action">{{ 'dashboard.desks.claim_as'|trans({'%name%': activeUser.name}) }}</button>
                                                                            </form>
                                                                        {% endif %}
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                    <div class="map-legend" aria-hidden="true">
                                                        <span><i class="map-dot free"></i> {{ 'dashboard.desks.legend.free'|trans }}</span>
                                                        <span><i class="map-dot busy"></i> {{ 'dashboard.desks.legend.busy'|trans }}</span>
                                                    </div>
                                                </div>
                                            </article>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>

                    <div class="content-tab-panel" data-content-tab="week">
                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.week.eyebrow'|trans }}</div>
                            <h2>{{ 'dashboard.week.title'|trans }}</h2>
                            <div class="week">
                                {% for day in weekOverview %}
                                    <div class="week-day">
                                        <strong>{{ day.date|date('D, d.m') }}</strong>
                                        <p class="muted">{{ 'dashboard.week.summary'|trans({'%occupied%': day.occupiedCount, '%free%': day.freeCount}) }}</p>
                                        <span class="pill vacation">{{ 'dashboard.week.vacation'|trans({'%count%': day.vacationCount}) }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </article>
                    </div>

                    <div class="content-tab-panel" data-content-tab="people">
                        <article class="panel">
                            <div class="eyebrow">{{ 'dashboard.people.eyebrow'|trans }}</div>
                            <h2>{{ 'dashboard.people.title'|trans }}</h2>
                            <div class="finder-search">
                                <label>
                                    {{ 'dashboard.people.search'|trans }}
                                    <input type="search" placeholder="{{ 'dashboard.people.placeholder'|trans }}" data-people-search-input>
                                </label>
                            </div>
                            <div class="people-list">
                                {% for person in peopleFinder %}
                                    <div class="people-card" data-people-search-item data-people-search-text="{{ (person.name ~ ' ' ~ person.team ~ ' ' ~ person.deskLabel ~ ' ' ~ person.statusLabel)|lower }}">
                                        <strong>{{ person.name }}</strong>
                                        <div class="muted">{{ person.team }}</div>
                                        <div>{{ person.deskLabel }}</div>
                                        <span class="pill none">{{ person.statusLabel }}</span>
                                    </div>
                                {% else %}
                                    <p class="muted">{{ 'dashboard.people.empty'|trans }}</p>
                                {% endfor %}
                            </div>
                        </article>
                    </div>

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="content-tab-panel" data-content-tab="admin-desks">
                            <article class="panel">
                                <div class="eyebrow">{{ 'dashboard.admin_desks.eyebrow'|trans }}</div>
                                <h2>{{ 'dashboard.admin_desks.title'|trans }}</h2>
                                <p class="lead">{{ 'dashboard.admin_desks.lead'|trans }}</p>

                                <form method="post" action="{{ path('app_admin_desk_label_update') }}">
                                    <input type="hidden" name="date" value="{{ selectedDate|date('Y-m-d') }}">
                                    <input type="hidden" name="activeUserId" value="{{ activeUser.id }}">
                                    <input type="hidden" name="tab" value="admin-desks">

                                    <div class="admin-desk-grid">
                                        {% for room in rooms %}
                                            {% for desk in room.desks %}
                                                <div class="admin-desk-form">
                                                    <div>
                                                        <strong>{{ desk.id }}</strong>
                                                        <span>{{ room.name }}</span>
                                                    </div>
                                                    <label>
                                                        {{ 'dashboard.admin_desks.label'|trans }}
                                                        <input type="text" name="labels[{{ desk.id }}]" value="{{ desk.label }}" maxlength="255" required>
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        {% endfor %}
                                    </div>

                                    <div style="margin-top: 20px;">
                                        <button type="submit">{{ 'dashboard.admin_desks.submit'|trans }}</button>
                                    </div>
                                </form>
                            </article>
                        </div>

                        <div class="content-tab-panel" data-content-tab="admin-reports">
                            <article class="panel stack">
                                <div>
                                    <div class="eyebrow">{{ 'dashboard.admin_reports.eyebrow'|trans }}</div>
                                    <h2>{{ 'dashboard.admin_reports.title'|trans }}</h2>
                                </div>

                                <div class="report-grid">
                                    <div class="report-card">
                                        <strong>{{ adminReports.openIssueCount }}</strong>
                                        <span class="muted">{{ 'dashboard.admin_reports.open_issues'|trans }}</span>
                                    </div>
                                    <div class="report-card">
                                        <strong>{{ adminReports.waitingCount }}</strong>
                                        <span class="muted">{{ 'dashboard.admin_reports.waiting'|trans }}</span>
                                    </div>
                                    <div class="report-card">
                                        <strong>{{ adminReports.recurringReservationCount }}</strong>
                                        <span class="muted">{{ 'dashboard.admin_reports.recurring'|trans }}</span>
                                    </div>
                                </div>

                                <div class="report-grid">
                                    <div class="report-list">
                                        <h3>{{ 'dashboard.admin_reports.top_busy'|trans }}</h3>
                                        {% for item in adminReports.topBusyDesks %}
                                            <div class="compact-item">
                                                <strong>{{ item.label }}</strong>
                                                <span class="muted">{{ item.roomName }}</span>
                                                <span>{{ 'dashboard.admin_reports.claim_count'|trans({'%count%': item.count}) }}</span>
                                            </div>
                                        {% else %}
                                            <p class="muted">{{ 'dashboard.admin_reports.top_busy_empty'|trans }}</p>
                                        {% endfor %}
                                    </div>

                                    <div class="report-list">
                                        <h3>{{ 'dashboard.admin_reports.top_waitlist'|trans }}</h3>
                                        {% for item in adminReports.topWaitlistedDesks %}
                                            <div class="compact-item">
                                                <strong>{{ item.label }}</strong>
                                                <span class="muted">{{ item.roomName }}</span>
                                                <span>{{ 'dashboard.admin_reports.waitlist_count'|trans({'%count%': item.count}) }}</span>
                                            </div>
                                        {% else %}
                                            <p class="muted">{{ 'dashboard.admin_reports.top_waitlist_empty'|trans }}</p>
                                        {% endfor %}
                                    </div>

                                    <div class="report-list">
                                        <h3>{{ 'dashboard.admin_reports.issues_by_category'|trans }}</h3>
                                        {% for item in adminReports.issuesByCategory %}
                                            <div class="compact-item">
                                                <strong>{{ item.label }}</strong>
                                                <span>{{ 'dashboard.admin_reports.issue_count'|trans({'%count%': item.count}) }}</span>
                                            </div>
                                        {% else %}
                                            <p class="muted">{{ 'dashboard.admin_reports.issues_empty'|trans }}</p>
                                        {% endfor %}
                                    </div>
                                </div>
                            </article>
                        </div>
                    {% endif %}
                </div>
            </section>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = Array.from(document.querySelectorAll('[data-desk-view-target]'));
            const views = Array.from(document.querySelectorAll('[data-desk-view]'));
            const contentTabButtons = Array.from(document.querySelectorAll('[data-content-tab-target]'));
            const contentTabPanels = Array.from(document.querySelectorAll('[data-content-tab]'));
            const userSearchInput = document.querySelector('[data-user-search-input]');
            const userSearchItems = Array.from(document.querySelectorAll('[data-user-search-item]'));
            const userSearchCount = document.querySelector('[data-user-search-count]');
            const userSearchEmpty = document.querySelector('[data-user-search-empty]');
            const peopleSearchInput = document.querySelector('[data-people-search-input]');
            const peopleSearchItems = Array.from(document.querySelectorAll('[data-people-search-item]'));
            const userSearchCountLabel = {{ 'dashboard.sidebar.users.count'|trans({'%visible%': '__visible__', '%total%': '__total__'})|json_encode|raw }};
            const url = new URL(window.location.href);
            const initialContentTab = url.searchParams.get('tab');

            function activateContentTab(target) {
                if (!target) {
                    return;
                }

                contentTabButtons.forEach(function (item) {
                    item.classList.toggle('active', item.getAttribute('data-content-tab-target') === target);
                });

                contentTabPanels.forEach(function (panel) {
                    panel.classList.toggle('active', panel.getAttribute('data-content-tab') === target);
                });
            }

            function normalizeSearchText(value) {
                return (value || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '');
            }

            function updateUserSearch() {
                if (!userSearchInput || userSearchItems.length === 0) {
                    return;
                }

                const phrase = normalizeSearchText(userSearchInput.value);
                let visibleCount = 0;

                userSearchItems.forEach(function (item) {
                    const haystack = normalizeSearchText(item.getAttribute('data-user-search-text'));
                    const matches = phrase === '' || haystack.includes(phrase);

                    item.classList.toggle('is-hidden', !matches);

                    if (matches) {
                        visibleCount += 1;
                    }
                });

                if (userSearchCount) {
                    userSearchCount.textContent = userSearchCountLabel
                        .replace('__visible__', String(visibleCount))
                        .replace('__total__', String(userSearchItems.length));
                }

                if (userSearchEmpty) {
                    userSearchEmpty.classList.toggle('visible', visibleCount === 0);
                }
            }

            function updatePeopleSearch() {
                if (!peopleSearchInput || peopleSearchItems.length === 0) {
                    return;
                }

                const phrase = normalizeSearchText(peopleSearchInput.value);

                peopleSearchItems.forEach(function (item) {
                    const haystack = normalizeSearchText(item.getAttribute('data-people-search-text'));
                    item.classList.toggle('is-hidden', phrase !== '' && !haystack.includes(phrase));
                });
            }

            buttons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const target = button.getAttribute('data-desk-view-target');

                    buttons.forEach(function (item) {
                        item.classList.toggle('active', item === button);
                    });

                    views.forEach(function (view) {
                        view.classList.toggle('active', view.getAttribute('data-desk-view') === target);
                    });
                });
            });

            contentTabButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    activateContentTab(button.getAttribute('data-content-tab-target'));
                });
            });

            if (userSearchInput) {
                userSearchInput.addEventListener('input', updateUserSearch);
                updateUserSearch();
            }

            if (peopleSearchInput) {
                peopleSearchInput.addEventListener('input', updatePeopleSearch);
                updatePeopleSearch();
            }

            activateContentTab(initialContentTab);
        });
    </script>
{% endblock %}
