{% extends 'base.html.twig' %}

{% block title %}{{ 'pricing.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --featured-label: "{{ 'pricing.featured'|trans }}";
            --pricing-bg: linear-gradient(180deg, #fbfdff 0%, #eef4ff 48%, #dce8ff 100%);
            --pricing-glow-a: rgba(83, 199, 255, 0.18);
            --pricing-glow-b: rgba(47, 124, 246, 0.14);
            --pricing-surface: rgba(255, 255, 255, 0.92);
            --pricing-surface-strong: rgba(255, 255, 255, 0.98);
            --pricing-border: rgba(15, 23, 42, 0.08);
            --pricing-text: #0f172a;
            --pricing-muted: #5f728f;
            --pricing-shadow: 0 24px 60px rgba(59, 87, 138, 0.16);
            --pricing-accent: #2f7cf6;
            --pricing-accent-strong: #1d4ed8;
            --pricing-accent-soft: rgba(47, 124, 246, 0.12);
            --pricing-success: #15b79e;
        }

        :root[data-theme="dark"] {
            --featured-label: "{{ 'pricing.featured'|trans }}";
            --pricing-bg: linear-gradient(180deg, #020712 0%, #08111f 48%, #0c1930 100%);
            --pricing-glow-a: rgba(18, 66, 123, 0.34);
            --pricing-glow-b: rgba(29, 78, 216, 0.22);
            --pricing-surface: rgba(7, 15, 28, 0.9);
            --pricing-surface-strong: rgba(10, 20, 36, 0.96);
            --pricing-border: rgba(140, 181, 255, 0.12);
            --pricing-text: #e5eefc;
            --pricing-muted: #9bb2d7;
            --pricing-shadow: 0 28px 80px rgba(1, 4, 12, 0.5);
            --pricing-accent: #53c7ff;
            --pricing-accent-strong: #2f7cf6;
            --pricing-accent-soft: rgba(83, 199, 255, 0.1);
            --pricing-success: #4ade80;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--pricing-text);
            background:
                radial-gradient(circle at top left, var(--pricing-glow-a), transparent 24%),
                radial-gradient(circle at 86% 10%, var(--pricing-glow-b), transparent 28%),
                var(--pricing-bg);
            min-height: 100vh;
        }

        .page {
            width: min(1240px, calc(100% - 32px));
            margin: 0 auto;
            padding: 36px 0 80px;
            display: grid;
            gap: 24px;
        }

        .hero,
        .section {
            background: var(--pricing-surface);
            border: 1px solid var(--pricing-border);
            border-radius: 30px;
            box-shadow: var(--pricing-shadow);
            backdrop-filter: blur(16px);
        }

        .hero {
            padding: 36px;
            display: grid;
            gap: 24px;
            grid-template-columns: 1.1fr 0.9fr;
            align-items: center;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--pricing-accent);
            margin-bottom: 14px;
        }

        h1, h2, h3, p {
            margin-top: 0;
        }

        h1 {
            font-size: clamp(2.8rem, 5vw, 4.8rem);
            line-height: 0.93;
            letter-spacing: -0.04em;
            max-width: 10ch;
            margin-bottom: 18px;
        }

        h2 {
            font-size: 1.55rem;
            letter-spacing: -0.03em;
            margin-bottom: 14px;
        }

        .lead {
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--pricing-muted);
            max-width: 58ch;
        }

        .hero-metrics,
        .plans,
        .compare-grid {
            display: grid;
            gap: 16px;
        }

        .hero-metrics {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .metric,
        .plan,
        .compare-card {
            padding: 20px;
            border-radius: 24px;
            background: var(--pricing-surface-strong);
            border: 1px solid var(--pricing-border);
        }

        .metric strong {
            display: block;
            font-size: 1.7rem;
            margin-bottom: 6px;
        }

        .metric span,
        .compare-card p,
        .plan p,
        .footnote {
            color: var(--pricing-muted);
            line-height: 1.7;
        }

        .section {
            padding: 28px;
        }

        .plans {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .plan {
            position: relative;
            overflow: hidden;
        }

        .plan.featured {
            border-color: color-mix(in srgb, var(--pricing-accent) 45%, var(--pricing-border));
            box-shadow: 0 24px 48px color-mix(in srgb, var(--pricing-accent) 24%, transparent);
        }

        .plan.featured::before {
            content: var(--featured-label);
            position: absolute;
            top: 18px;
            right: 18px;
            padding: 7px 11px;
            border-radius: 999px;
            background: var(--pricing-accent-soft);
            color: var(--pricing-accent-strong);
            font-size: 0.74rem;
            font-weight: 800;
        }

        .plan-header {
            padding-right: 112px;
            margin-bottom: 18px;
        }

        .plan-price {
            display: flex;
            align-items: baseline;
            gap: 8px;
            margin: 18px 0 6px;
        }

        .plan-price strong {
            font-size: 2.7rem;
            letter-spacing: -0.05em;
        }

        .plan ul {
            list-style: none;
            padding: 0;
            margin: 18px 0 0;
            display: grid;
            gap: 10px;
        }

        .plan li {
            display: flex;
            gap: 10px;
            color: var(--pricing-text);
        }

        .plan li::before {
            content: "•";
            color: var(--pricing-success);
            font-weight: 900;
        }

        .plan-actions {
            margin-top: 22px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .button,
        .button-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 13px 18px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
        }

        .button {
            background: linear-gradient(135deg, var(--pricing-accent-strong) 0%, var(--pricing-accent) 100%);
            color: #eff6ff;
        }

        .button-secondary {
            border: 1px solid var(--pricing-border);
            background: var(--pricing-surface-strong);
            color: var(--pricing-text);
        }

        .compare-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .compare-card strong {
            display: block;
            margin-bottom: 8px;
            font-size: 1.05rem;
        }

        @media (max-width: 980px) {
            .hero,
            .plans,
            .compare-grid {
                grid-template-columns: 1fr;
            }

            .hero-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 720px) {
            .page {
                width: min(100%, calc(100% - 20px));
                padding: 20px 0 86px;
            }

            .hero,
            .section {
                padding: 22px;
            }

            .hero-metrics {
                grid-template-columns: 1fr;
            }

            .plan-header {
                padding-right: 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <section class="hero">
            <div>
                <div class="eyebrow">{{ 'pricing.eyebrow'|trans }}</div>
                <h1>{{ 'pricing.hero.title'|trans }}</h1>
                <p class="lead">{{ 'pricing.hero.body'|trans }}</p>

                <div class="plan-actions">
                    <a class="button" href="{{ path('app_register') }}">{{ 'pricing.hero.cta_primary'|trans }}</a>
                    <a class="button-secondary" href="{{ path('app_about') }}">{{ 'pricing.hero.cta_secondary'|trans }}</a>
                </div>
            </div>

            <div class="hero-metrics">
                <div class="metric">
                    <strong>{{ 'pricing.metrics.plans.title'|trans }}</strong>
                    <span>{{ 'pricing.metrics.plans.body'|trans }}</span>
                </div>
                <div class="metric">
                    <strong>{{ 'pricing.metrics.flow.title'|trans }}</strong>
                    <span>{{ 'pricing.metrics.flow.body'|trans }}</span>
                </div>
                <div class="metric">
                    <strong>{{ 'pricing.metrics.people.title'|trans }}</strong>
                    <span>{{ 'pricing.metrics.people.body'|trans }}</span>
                </div>
                <div class="metric">
                    <strong>{{ 'pricing.metrics.admin.title'|trans }}</strong>
                    <span>{{ 'pricing.metrics.admin.body'|trans }}</span>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="eyebrow">{{ 'pricing.packages.eyebrow'|trans }}</div>
            <h2>{{ 'pricing.packages.title'|trans }}</h2>

            <div class="plans">
                <article class="plan">
                    <div class="plan-header">
                        <h3>{{ 'pricing.starter.title'|trans }}</h3>
                        <p>{{ 'pricing.starter.body'|trans }}</p>
                    </div>

                    <div class="plan-price">
                        <strong>{{ 'pricing.starter.price'|trans }}</strong>
                        <span>{{ 'pricing.per_user_month'|trans }}</span>
                    </div>

                    <ul>
                        <li>{{ 'pricing.starter.feature_1'|trans }}</li>
                        <li>{{ 'pricing.starter.feature_2'|trans }}</li>
                        <li>{{ 'pricing.starter.feature_3'|trans }}</li>
                        <li>{{ 'pricing.starter.feature_4'|trans }}</li>
                        <li>{{ 'pricing.starter.feature_5'|trans }}</li>
                    </ul>

                    <div class="plan-actions">
                        <a class="button-secondary" href="{{ path('app_register') }}">{{ 'pricing.starter.cta'|trans }}</a>
                    </div>
                </article>

                <article class="plan featured">
                    <div class="plan-header">
                        <h3>{{ 'pricing.growth.title'|trans }}</h3>
                        <p>{{ 'pricing.growth.body'|trans }}</p>
                    </div>

                    <div class="plan-price">
                        <strong>{{ 'pricing.growth.price'|trans }}</strong>
                        <span>{{ 'pricing.per_user_month'|trans }}</span>
                    </div>

                    <ul>
                        <li>{{ 'pricing.growth.feature_1'|trans }}</li>
                        <li>{{ 'pricing.growth.feature_2'|trans }}</li>
                        <li>{{ 'pricing.growth.feature_3'|trans }}</li>
                        <li>{{ 'pricing.growth.feature_4'|trans }}</li>
                        <li>{{ 'pricing.growth.feature_5'|trans }}</li>
                        <li>{{ 'pricing.growth.feature_6'|trans }}</li>
                    </ul>

                    <div class="plan-actions">
                        <a class="button" href="{{ path('app_about') }}">{{ 'pricing.growth.cta'|trans }}</a>
                    </div>
                </article>

                <article class="plan">
                    <div class="plan-header">
                        <h3>{{ 'pricing.enterprise.title'|trans }}</h3>
                        <p>{{ 'pricing.enterprise.body'|trans }}</p>
                    </div>

                    <div class="plan-price">
                        <strong>{{ 'pricing.enterprise.price'|trans }}</strong>
                        <span>{{ 'pricing.enterprise.price_note'|trans }}</span>
                    </div>

                    <ul>
                        <li>{{ 'pricing.enterprise.feature_1'|trans }}</li>
                        <li>{{ 'pricing.enterprise.feature_2'|trans }}</li>
                        <li>{{ 'pricing.enterprise.feature_3'|trans }}</li>
                        <li>{{ 'pricing.enterprise.feature_4'|trans }}</li>
                        <li>{{ 'pricing.enterprise.feature_5'|trans }}</li>
                    </ul>

                    <div class="plan-actions">
                        <a class="button-secondary" href="{{ path('app_login') }}">{{ 'pricing.enterprise.cta'|trans }}</a>
                    </div>
                </article>
            </div>
        </section>

        <section class="section">
            <div class="eyebrow">{{ 'pricing.value.eyebrow'|trans }}</div>
            <h2>{{ 'pricing.value.title'|trans }}</h2>

            <div class="compare-grid">
                <article class="compare-card">
                    <strong>{{ 'pricing.value.space.title'|trans }}</strong>
                    <p>{{ 'pricing.value.space.body'|trans }}</p>
                </article>
                <article class="compare-card">
                    <strong>{{ 'pricing.value.process.title'|trans }}</strong>
                    <p>{{ 'pricing.value.process.body'|trans }}</p>
                </article>
                <article class="compare-card">
                    <strong>{{ 'pricing.value.future.title'|trans }}</strong>
                    <p>{{ 'pricing.value.future.body'|trans }}</p>
                </article>
            </div>
        </section>

        <p class="footnote">{{ 'pricing.footer'|trans }}</p>
    </div>
{% endblock %}
