{% extends 'base.html.twig' %}

{% block title %}Logowanie{% endblock %}

{% block stylesheets %}
    <style>
        body { margin: 0; min-height: 100vh; font-family: "Manrope", "Segoe UI", sans-serif; background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%); color: #0f172a; }
        .auth-shell { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
        .auth-card { width: min(100%, 460px); background: rgba(255,255,255,0.94); border: 1px solid rgba(148,163,184,0.22); border-radius: 28px; padding: 28px; box-shadow: 0 24px 60px rgba(15,23,42,0.12); }
        h1, p { margin-top: 0; }
        form, .stack { display: grid; gap: 14px; }
        label { display: grid; gap: 8px; font-weight: 700; }
        input, button { font: inherit; border-radius: 16px; padding: 14px 16px; }
        input { border: 1px solid rgba(148,163,184,0.25); }
        button { border: 0; color: #fff; font-weight: 800; background: linear-gradient(135deg, #145af2 0%, #2563eb 100%); }
        .muted { color: #64748b; }
        .flash, .error { padding: 12px 14px; border-radius: 16px; font-weight: 700; }
        .flash.success { background: rgba(15,159,110,0.1); color: #0f9f6e; }
        .flash.error, .error { background: rgba(220,38,38,0.08); color: #dc2626; }
        a { color: #145af2; font-weight: 700; text-decoration: none; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-shell">
        <div class="auth-card">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <div class="stack">
                <div>
                    <h1>Zaloguj sie</h1>
                    <p class="muted">Uzyj emaila i hasla przypisanego do konta. Logowanie jest dostepne dopiero po potwierdzeniu adresu email.</p>
                </div>

                {% if error %}
                    <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <label>
                        Email
                        <input type="email" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
                    </label>

                    <label>
                        Haslo
                        <input type="password" name="_password" autocomplete="current-password" required>
                    </label>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit">Zaloguj sie</button>
                </form>

                <p class="muted">Nie masz konta? <a href="{{ path('app_register') }}">Zarejestruj sie</a></p>
            </div>
        </div>
    </div>
{% endblock %}
