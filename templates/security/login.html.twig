{% extends 'base.html.twig' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --auth-bg: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
            --auth-text: #0f172a;
            --auth-card: rgba(255,255,255,0.94);
            --auth-card-border: rgba(148,163,184,0.22);
            --auth-field-bg: #ffffff;
            --auth-field-border: rgba(148,163,184,0.25);
            --auth-muted: #64748b;
            --auth-shadow: 0 24px 60px rgba(15,23,42,0.12);
        }

        :root[data-theme="dark"] {
            --auth-bg: linear-gradient(180deg, #071120 0%, #0c1730 100%);
            --auth-text: #e2e8f0;
            --auth-card: rgba(9,18,34,0.92);
            --auth-card-border: rgba(148,163,184,0.14);
            --auth-field-bg: rgba(15,23,42,0.78);
            --auth-field-border: rgba(148,163,184,0.18);
            --auth-muted: #94a3b8;
            --auth-shadow: 0 24px 60px rgba(2,6,23,0.38);
        }

        body { margin: 0; min-height: 100vh; font-family: "Manrope", "Segoe UI", sans-serif; background: var(--auth-bg); color: var(--auth-text); transition: background 180ms ease, color 180ms ease; }
        .auth-shell { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
        .auth-card { width: min(100%, 460px); background: var(--auth-card); border: 1px solid var(--auth-card-border); border-radius: 28px; padding: 28px; box-shadow: var(--auth-shadow); }
        h1, p { margin-top: 0; }
        form, .stack { display: grid; gap: 14px; }
        label { display: grid; gap: 8px; font-weight: 700; }
        input, button { font: inherit; border-radius: 16px; padding: 14px 16px; }
        input { border: 1px solid var(--auth-field-border); background: var(--auth-field-bg); color: var(--auth-text); }
        button { border: 0; color: #fff; font-weight: 800; background: linear-gradient(135deg, #145af2 0%, #2563eb 100%); }
        .muted { color: var(--auth-muted); }
        .flash, .error { padding: 12px 14px; border-radius: 16px; font-weight: 700; }
        .flash.success { background: rgba(15,159,110,0.1); color: #0f9f6e; }
        .flash.error, .error { background: rgba(220,38,38,0.08); color: #dc2626; }
        .dev-hint { display: grid; gap: 10px; padding: 16px 18px; border-radius: 20px; border: 1px dashed var(--auth-field-border); background: color-mix(in srgb, var(--auth-card) 88%, transparent); }
        .dev-hint strong { font-size: 0.92rem; }
        .dev-hint select { border: 1px solid var(--auth-field-border); background: var(--auth-field-bg); color: var(--auth-text); border-radius: 14px; padding: 12px 14px; font: inherit; }
        a { color: #145af2; font-weight: 700; text-decoration: none; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-shell">
        <div class="auth-card">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <div class="stack">
                <div>
                    <h1>{{ 'login.title'|trans }}</h1>
                    <p class="muted">{{ 'login.subtitle'|trans }}</p>
                </div>

                {% if error %}
                    <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post" data-login-form>
                    <label>
                        {{ 'common.email'|trans }}
                        <input type="email" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus data-login-username>
                    </label>

                    <label>
                        {{ 'common.password'|trans }}
                        <input type="password" name="_password" autocomplete="current-password" required data-login-password>
                    </label>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit">{{ 'login.submit'|trans }}</button>
                </form>

                <p class="muted">{{ 'login.no_account'|trans }} <a href="{{ path('app_register') }}">{{ 'register.link'|trans }}</a></p>

                {% if app.environment == 'dev' %}
                    <div class="dev-hint">
                        <strong>{{ 'login.dev.title'|trans }}</strong>
                        <label>
                            {{ 'login.dev.account'|trans }}
                            <select data-login-preset>
                                <option value="anna.kowalska@example.com|password123">Anna Kowalska</option>
                                <option value="piotr.nowak@example.com|password123">Piotr Nowak (admin)</option>
                                <option value="marta.zielinska@example.com|password123">Marta Zielinska</option>
                                <option value="tomasz.wisniewski@example.com|password123">Tomasz Wisniewski</option>
                                <option value="julia.kaczmarek@example.com|password123">Julia Kaczmarek</option>
                            </select>
                        </label>
                        <p class="muted">{{ 'login.dev.hint'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if app.environment == 'dev' %}
        <script>
            (() => {
                const preset = document.querySelector('[data-login-preset]');
                const username = document.querySelector('[data-login-username]');
                const password = document.querySelector('[data-login-password]');

                if (!preset || !username || !password) {
                    return;
                }

                const applyPreset = () => {
                    const [email, plainPassword] = preset.value.split('|');
                    username.value = email ?? '';
                    password.value = plainPassword ?? '';
                };

                if (!username.value && !password.value) {
                    applyPreset();
                }

                preset.addEventListener('change', applyPreset);
            })();
        </script>
    {% endif %}
{% endblock %}
