{% extends 'base.html.twig' %}

{% block title %}{{ 'register.title'|trans }}{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --auth-bg: linear-gradient(180deg, #f5f5f4 0%, #e7e5e4 100%);
            --auth-text: #292524;
            --auth-card: rgba(255,255,255,0.9);
            --auth-card-border: rgba(87,83,78,0.16);
            --auth-field-bg: #fafaf9;
            --auth-field-border: rgba(87,83,78,0.18);
            --auth-muted: #78716c;
            --auth-shadow: 0 24px 60px rgba(41,37,36,0.10);
        }

        :root[data-theme="dark"] {
            --auth-bg: linear-gradient(180deg, #18181b 0%, #27272a 100%);
            --auth-text: #f4f4f5;
            --auth-card: rgba(39,39,42,0.92);
            --auth-card-border: rgba(120,113,108,0.18);
            --auth-field-bg: rgba(24,24,27,0.82);
            --auth-field-border: rgba(120,113,108,0.22);
            --auth-muted: #a8a29e;
            --auth-shadow: 0 24px 60px rgba(0,0,0,0.34);
        }

        body { margin: 0; min-height: 100vh; font-family: "Manrope", "Segoe UI", sans-serif; background: var(--auth-bg); color: var(--auth-text); transition: background 180ms ease, color 180ms ease; }
        .auth-shell { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
        .auth-card { width: min(100%, 760px); background: var(--auth-card); border: 1px solid var(--auth-card-border); border-radius: 28px; padding: 28px; box-shadow: var(--auth-shadow); }
        h1, h2, p { margin-top: 0; }
        form, .stack, .grid, .days { display: grid; gap: 14px; }
        .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        label { display: grid; gap: 8px; font-weight: 700; }
        input, select, button { font: inherit; border-radius: 16px; padding: 14px 16px; }
        input, select { border: 1px solid var(--auth-field-border); background: var(--auth-field-bg); color: var(--auth-text); }
        button { border: 0; color: #fff; font-weight: 800; background: linear-gradient(135deg, #3f3f46 0%, #71717a 100%); }
        .muted { color: var(--auth-muted); }
        .flash {
            padding: 13px 15px;
            border-radius: 16px;
            font-weight: 700;
            line-height: 1.5;
            border: 1px solid var(--auth-field-border);
        }
        .flash.success {
            background: rgba(34, 197, 94, 0.12);
            border-color: rgba(34, 197, 94, 0.2);
            color: #14532d;
        }
        .flash.error {
            background: rgba(239, 68, 68, 0.12);
            border-color: rgba(239, 68, 68, 0.2);
            color: #7f1d1d;
        }
        :root[data-theme="dark"] .flash.success {
            background: rgba(34, 197, 94, 0.18);
            border-color: rgba(74, 222, 128, 0.22);
            color: #dcfce7;
        }
        :root[data-theme="dark"] .flash.error {
            background: rgba(239, 68, 68, 0.18);
            border-color: rgba(248, 113, 113, 0.22);
            color: #fee2e2;
        }
        .days { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .checkbox { display: flex; gap: 10px; align-items: center; font-weight: 600; padding: 12px 14px; border-radius: 16px; border: 1px solid var(--auth-field-border); }
        .checkbox input { padding: 0; }
        a { color: #44403c; font-weight: 700; text-decoration: none; }
        @media (max-width: 720px) { .grid, .days { grid-template-columns: 1fr; } }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-shell">
        <div class="auth-card">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <div class="stack">
                <div>
                    <h1>{{ 'register.title'|trans }}</h1>
                    <p class="muted">{{ 'register.subtitle'|trans }}</p>
                </div>

                <form method="post">
                    <div class="grid">
                        <label>
                            {{ 'common.full_name'|trans }}
                            <input type="text" name="name" value="{{ values.name }}" required>
                        </label>
                        <label>
                            {{ 'common.team'|trans }}
                            <input type="text" name="team" value="{{ values.team }}" required>
                        </label>
                        <label>
                            {{ 'common.email'|trans }}
                            <input type="email" name="email" value="{{ values.email }}" required>
                        </label>
                        <label>
                            {{ 'common.password'|trans }}
                            <input type="password" name="password" required minlength="8">
                        </label>
                        <label>
                            {{ 'common.language'|trans }}
                            <select name="locale" required>
                                {% for locale in languageOptions %}
                                    <option value="{{ locale }}" {% if values.locale == locale %}selected{% endif %}>{{ ('language.option.' ~ locale)|trans }}</option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>

                    <label>
                        {{ 'register.assigned_desk.label'|trans }}
                        <select name="assignedDeskId">
                            <option value="">{{ 'register.assigned_desk.none'|trans }}</option>
                            {% for deskId, desk in deskOptions %}
                                <option value="{{ deskId }}" {% if values.assignedDeskId == deskId %}selected{% endif %}>{{ desk.label }} / {{ desk.roomName }}</option>
                            {% endfor %}
                        </select>
                    </label>

                    <div>
                        <h2>{{ 'register.schedule.title'|trans }}</h2>
                        <div class="days">
                            {% for key in ['monday', 'tuesday', 'wednesday', 'thursday', 'friday'] %}
                                <label class="checkbox">
                                    <input type="checkbox" name="schedule[]" value="{{ key }}" {% if key in values.schedule %}checked{% endif %}>
                                    <span>{{ ('weekday.long.' ~ key)|trans }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>

                    <button type="submit">{{ 'register.submit'|trans }}</button>
                </form>

                <p class="muted">{{ 'register.has_account'|trans }} <a href="{{ path('app_login') }}">{{ 'login.link'|trans }}</a></p>
            </div>
        </div>
    </div>
{% endblock %}
