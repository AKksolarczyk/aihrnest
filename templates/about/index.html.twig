{% extends 'base.html.twig' %}

{% block title %}{{ 'about.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --about-bg: linear-gradient(180deg, #fafaf9 0%, #f5f5f4 52%, #e7e5e4 100%);
            --about-glow-a: rgba(168, 162, 158, 0.14);
            --about-glow-b: rgba(120, 113, 108, 0.10);
            --about-surface: rgba(255, 255, 255, 0.92);
            --about-surface-strong: rgba(255, 255, 255, 0.98);
            --about-border: rgba(41, 37, 36, 0.08);
            --about-text: #292524;
            --about-muted: #78716c;
            --about-shadow: 0 24px 60px rgba(41, 37, 36, 0.12);
            --about-accent: #71717a;
            --about-accent-strong: #3f3f46;
        }

        :root[data-theme="dark"] {
            --about-bg: linear-gradient(180deg, #18181b 0%, #27272a 52%, #3f3f46 100%);
            --about-glow-a: rgba(120, 113, 108, 0.18);
            --about-glow-b: rgba(168, 162, 158, 0.10);
            --about-surface: rgba(39, 39, 42, 0.9);
            --about-surface-strong: rgba(63, 63, 70, 0.96);
            --about-border: rgba(168, 162, 158, 0.12);
            --about-text: #fafaf9;
            --about-muted: #a8a29e;
            --about-shadow: 0 28px 80px rgba(0, 0, 0, 0.42);
            --about-accent: #e7e5e4;
            --about-accent-strong: #a8a29e;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--about-text);
            background:
                radial-gradient(circle at top left, var(--about-glow-a), transparent 24%),
                radial-gradient(circle at 86% 10%, var(--about-glow-b), transparent 28%),
                var(--about-bg);
            min-height: 100vh;
        }

        .page {
            width: min(1200px, calc(100% - 32px));
            margin: 0 auto;
            padding: 36px 0 72px;
            display: grid;
            gap: 24px;
        }

        .hero,
        .section {
            background: var(--about-surface);
            border: 1px solid var(--about-border);
            border-radius: 30px;
            box-shadow: var(--about-shadow);
            backdrop-filter: blur(16px);
        }

        .hero {
            padding: 34px;
            display: grid;
            gap: 24px;
            grid-template-columns: 1.15fr 0.85fr;
            align-items: end;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--about-accent);
            margin-bottom: 14px;
        }

        h1, h2, h3, p {
            margin-top: 0;
        }

        h1 {
            font-size: clamp(2.8rem, 5vw, 4.8rem);
            line-height: 0.93;
            letter-spacing: -0.04em;
            max-width: 10ch;
            margin-bottom: 18px;
        }

        h2 {
            font-size: 1.55rem;
            letter-spacing: -0.03em;
            margin-bottom: 14px;
        }

        .lead {
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--about-muted);
            max-width: 58ch;
        }

        .hero-actions,
        .hero-pills,
        .stack,
        .grid {
            display: grid;
            gap: 14px;
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .button,
        .button-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 13px 18px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
        }

        .button {
            background: linear-gradient(135deg, var(--about-accent-strong) 0%, var(--about-accent) 100%);
            color: #eff6ff;
        }

        .button-secondary {
            border: 1px solid var(--about-border);
            background: var(--about-surface-strong);
            color: var(--about-text);
        }

        .hero-pills {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .pill {
            padding: 16px 18px;
            border-radius: 22px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .pill strong {
            display: block;
            font-size: 1.5rem;
            margin-bottom: 6px;
        }

        .pill span {
            color: var(--about-muted);
            font-size: 0.92rem;
        }

        .section {
            padding: 28px;
        }

        .grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .card {
            padding: 20px;
            border-radius: 24px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .card p,
        .stack p {
            color: var(--about-muted);
            line-height: 1.7;
        }

        .tech-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .tech {
            padding: 18px;
            border-radius: 22px;
            background: linear-gradient(180deg, color-mix(in srgb, var(--about-surface-strong) 92%, transparent) 0%, var(--about-surface) 100%);
            border: 1px solid var(--about-border);
        }

        .tech small {
            display: block;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--about-accent);
            font-weight: 800;
        }

        .timeline {
            display: grid;
            gap: 16px;
        }

        .step {
            display: grid;
            grid-template-columns: 72px 1fr;
            gap: 18px;
            align-items: start;
            padding: 18px;
            border-radius: 22px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .step-number {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, var(--about-accent-strong) 0%, var(--about-accent) 100%);
            color: #eff6ff;
            font-size: 1.2rem;
            font-weight: 800;
        }

        .footer-note {
            color: var(--about-muted);
            font-size: 0.95rem;
        }

        @media (max-width: 980px) {
            .hero,
            .grid,
            .tech-grid {
                grid-template-columns: 1fr;
            }

            .hero-pills {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 720px) {
            .page {
                width: min(100%, calc(100% - 20px));
                padding: 20px 0 80px;
            }

            .hero,
            .section {
                padding: 22px;
            }

            .hero-pills,
            .step {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <section class="hero">
            <div>
                <div class="eyebrow">{{ 'about.eyebrow'|trans }}</div>
                <h1>{{ 'about.hero.title'|trans }}</h1>
                <p class="lead">{{ 'about.hero.lead'|trans }}</p>

                <div class="hero-actions">
                    <a class="button" href="{{ path('app_login') }}">{{ 'about.hero.login'|trans }}</a>
                    <a class="button-secondary" href="{{ path('app_register') }}">{{ 'about.hero.register'|trans }}</a>
                    <a class="button-secondary" href="{{ path('app_dashboard') }}">{{ 'about.hero.dashboard'|trans }}</a>
                </div>
            </div>

            <div class="hero-pills">
                <div class="pill">
                    <strong>{{ 'about.pill.booking_title'|trans }}</strong>
                    <span>{{ 'about.pill.booking'|trans }}</span>
                </div>
                <div class="pill">
                    <strong>{{ 'about.pill.waitlist_title'|trans }}</strong>
                    <span>{{ 'about.pill.waitlist'|trans }}</span>
                </div>
                <div class="pill">
                    <strong>{{ 'about.pill.people_title'|trans }}</strong>
                    <span>{{ 'about.pill.people'|trans }}</span>
                </div>
                <div class="pill">
                    <strong>{{ 'about.pill.reports_title'|trans }}</strong>
                    <span>{{ 'about.pill.reports'|trans }}</span>
                </div>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">{{ 'about.features.eyebrow'|trans }}</div>
                <h2>{{ 'about.features.title'|trans }}</h2>
            </div>

            <div class="grid">
                <article class="card">
                    <h3>{{ 'about.features.registration.title'|trans }}</h3>
                    <p>{{ 'about.features.registration.body'|trans }}</p>
                </article>
                <article class="card">
                    <h3>{{ 'about.features.dashboard.title'|trans }}</h3>
                    <p>{{ 'about.features.dashboard.body'|trans }}</p>
                </article>
                <article class="card">
                    <h3>{{ 'about.features.booking.title'|trans }}</h3>
                    <p>{{ 'about.features.booking.body'|trans }}</p>
                </article>
                <article class="card">
                    <h3>{{ 'about.features.absence.title'|trans }}</h3>
                    <p>{{ 'about.features.absence.body'|trans }}</p>
                </article>
                <article class="card">
                    <h3>{{ 'about.features.waitlist.title'|trans }}</h3>
                    <p>{{ 'about.features.waitlist.body'|trans }}</p>
                </article>
                <article class="card">
                    <h3>{{ 'about.features.reporting.title'|trans }}</h3>
                    <p>{{ 'about.features.reporting.body'|trans }}</p>
                </article>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">{{ 'about.stack.eyebrow'|trans }}</div>
                <h2>{{ 'about.stack.title'|trans }}</h2>
            </div>

            <div class="tech-grid">
                <article class="tech">
                    <small>Backend</small>
                    <strong>PHP 8.4 + Symfony 7.4</strong>
                    <p>{{ 'about.stack.backend'|trans }}</p>
                </article>
                <article class="tech">
                    <small>{{ 'about.stack.architecture.label'|trans }}</small>
                    <strong>DDD + CQRS</strong>
                    <p>{{ 'about.stack.architecture.body'|trans }}</p>
                </article>
                <article class="tech">
                    <small>{{ 'about.stack.persistence.label'|trans }}</small>
                    <strong>Doctrine ORM + PostgreSQL</strong>
                    <p>{{ 'about.stack.persistence.body'|trans }}</p>
                </article>
                <article class="tech">
                    <small>Local Dev</small>
                    <strong>Docker + Traefik + Mailpit</strong>
                    <p>{{ 'about.stack.dev'|trans }}</p>
                </article>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">{{ 'about.flow.eyebrow'|trans }}</div>
                <h2>{{ 'about.flow.title'|trans }}</h2>
            </div>

            <div class="timeline">
                <article class="step">
                    <div class="step-number">1</div>
                    <div>
                        <h3>{{ 'about.flow.step1.title'|trans }}</h3>
                        <p>{{ 'about.flow.step1.body'|trans }}</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">2</div>
                    <div>
                        <h3>{{ 'about.flow.step2.title'|trans }}</h3>
                        <p>{{ 'about.flow.step2.body'|trans }}</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">3</div>
                    <div>
                        <h3>{{ 'about.flow.step3.title'|trans }}</h3>
                        <p>{{ 'about.flow.step3.body'|trans }}</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">4</div>
                    <div>
                        <h3>{{ 'about.flow.step4.title'|trans }}</h3>
                        <p>{{ 'about.flow.step4.body'|trans }}</p>
                    </div>
                </article>
            </div>
        </section>

        <p class="footer-note">{{ 'about.footer'|trans }}</p>
    </div>
{% endblock %}
