{% extends 'base.html.twig' %}

{% block title %}About Smart Desk{% endblock %}

{% block stylesheets %}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

        :root {
            --about-bg: linear-gradient(180deg, #f8fbff 0%, #eef4ff 52%, #dde9ff 100%);
            --about-glow-a: rgba(83, 199, 255, 0.18);
            --about-glow-b: rgba(47, 124, 246, 0.14);
            --about-surface: rgba(255, 255, 255, 0.92);
            --about-surface-strong: rgba(255, 255, 255, 0.98);
            --about-border: rgba(15, 23, 42, 0.08);
            --about-text: #0f172a;
            --about-muted: #5f728f;
            --about-shadow: 0 24px 60px rgba(59, 87, 138, 0.16);
            --about-accent: #2f7cf6;
            --about-accent-strong: #1d4ed8;
        }

        :root[data-theme="dark"] {
            --about-bg: linear-gradient(180deg, #020712 0%, #08111f 52%, #0c1930 100%);
            --about-glow-a: rgba(18, 66, 123, 0.34);
            --about-glow-b: rgba(29, 78, 216, 0.22);
            --about-surface: rgba(7, 15, 28, 0.9);
            --about-surface-strong: rgba(10, 20, 36, 0.96);
            --about-border: rgba(140, 181, 255, 0.12);
            --about-text: #e5eefc;
            --about-muted: #9bb2d7;
            --about-shadow: 0 28px 80px rgba(1, 4, 12, 0.5);
            --about-accent: #53c7ff;
            --about-accent-strong: #2f7cf6;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--about-text);
            background:
                radial-gradient(circle at top left, var(--about-glow-a), transparent 24%),
                radial-gradient(circle at 86% 10%, var(--about-glow-b), transparent 28%),
                var(--about-bg);
            min-height: 100vh;
        }

        .page {
            width: min(1200px, calc(100% - 32px));
            margin: 0 auto;
            padding: 36px 0 72px;
            display: grid;
            gap: 24px;
        }

        .hero,
        .section {
            background: var(--about-surface);
            border: 1px solid var(--about-border);
            border-radius: 30px;
            box-shadow: var(--about-shadow);
            backdrop-filter: blur(16px);
        }

        .hero {
            padding: 34px;
            display: grid;
            gap: 24px;
            grid-template-columns: 1.15fr 0.85fr;
            align-items: end;
        }

        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--about-accent);
            margin-bottom: 14px;
        }

        h1, h2, h3, p {
            margin-top: 0;
        }

        h1 {
            font-size: clamp(2.8rem, 5vw, 4.8rem);
            line-height: 0.93;
            letter-spacing: -0.04em;
            max-width: 10ch;
            margin-bottom: 18px;
        }

        h2 {
            font-size: 1.55rem;
            letter-spacing: -0.03em;
            margin-bottom: 14px;
        }

        .lead {
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--about-muted);
            max-width: 58ch;
        }

        .hero-actions,
        .hero-pills,
        .stack,
        .grid {
            display: grid;
            gap: 14px;
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .button,
        .button-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 13px 18px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
        }

        .button {
            background: linear-gradient(135deg, var(--about-accent-strong) 0%, var(--about-accent) 100%);
            color: #eff6ff;
        }

        .button-secondary {
            border: 1px solid var(--about-border);
            background: var(--about-surface-strong);
            color: var(--about-text);
        }

        .hero-pills {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .pill {
            padding: 16px 18px;
            border-radius: 22px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .pill strong {
            display: block;
            font-size: 1.5rem;
            margin-bottom: 6px;
        }

        .pill span {
            color: var(--about-muted);
            font-size: 0.92rem;
        }

        .section {
            padding: 28px;
        }

        .grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .card {
            padding: 20px;
            border-radius: 24px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .card p,
        .stack p {
            color: var(--about-muted);
            line-height: 1.7;
        }

        .tech-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .tech {
            padding: 18px;
            border-radius: 22px;
            background: linear-gradient(180deg, color-mix(in srgb, var(--about-surface-strong) 92%, transparent) 0%, var(--about-surface) 100%);
            border: 1px solid var(--about-border);
        }

        .tech small {
            display: block;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--about-accent);
            font-weight: 800;
        }

        .timeline {
            display: grid;
            gap: 16px;
        }

        .step {
            display: grid;
            grid-template-columns: 72px 1fr;
            gap: 18px;
            align-items: start;
            padding: 18px;
            border-radius: 22px;
            background: var(--about-surface-strong);
            border: 1px solid var(--about-border);
        }

        .step-number {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, var(--about-accent-strong) 0%, var(--about-accent) 100%);
            color: #eff6ff;
            font-size: 1.2rem;
            font-weight: 800;
        }

        .footer-note {
            color: var(--about-muted);
            font-size: 0.95rem;
        }

        @media (max-width: 980px) {
            .hero,
            .grid,
            .tech-grid {
                grid-template-columns: 1fr;
            }

            .hero-pills {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 720px) {
            .page {
                width: min(100%, calc(100% - 20px));
                padding: 20px 0 80px;
            }

            .hero,
            .section {
                padding: 22px;
            }

            .hero-pills,
            .step {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page">
        <section class="hero">
            <div>
                <div class="eyebrow">Smart Desk & Rooms Scheduler</div>
                <h1>Biurka, sale i nieobecnosci w jednej aplikacji.</h1>
                <p class="lead">
                    Smart Desk porzadkuje planowanie pracy z biura. Pokazuje dostepnosc zasobow w widoku dnia,
                    pozwala rezerwowac biurka i przygotowuje fundament pod zarzadzanie salami konferencyjnymi oraz
                    integracje absencji z systemem HR.
                </p>

                <div class="hero-actions">
                    <a class="button" href="{{ path('app_login') }}">Przejdz do logowania</a>
                    <a class="button-secondary" href="{{ path('app_register') }}">Utworz konto</a>
                    <a class="button-secondary" href="{{ path('app_dashboard') }}">Otworz dashboard</a>
                </div>
            </div>

            <div class="hero-pills">
                <div class="pill">
                    <strong>Desk Booking</strong>
                    <span>Rezerwacja biurek na konkretny dzien z widokiem mapy biura.</span>
                </div>
                <div class="pill">
                    <strong>Absence Logic</strong>
                    <span>Wewnetrzny model urlopow i blokad dostepnosci zasobow.</span>
                </div>
                <div class="pill">
                    <strong>Account Activation</strong>
                    <span>Rejestracja z mailem aktywacyjnym i blokada logowania do czasu potwierdzenia.</span>
                </div>
                <div class="pill">
                    <strong>DDD + CQRS</strong>
                    <span>Rozdzial logiki biznesowej, use case'ow i warstw infrastrukturalnych.</span>
                </div>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">Mozliwosci aplikacji</div>
                <h2>Co potrafi system na obecnym etapie</h2>
            </div>

            <div class="grid">
                <article class="card">
                    <h3>Rejestracja i aktywacja konta</h3>
                    <p>Uzytkownik zaklada konto, dostaje mail aktywacyjny i dopiero po potwierdzeniu moze sie zalogowac.</p>
                </article>
                <article class="card">
                    <h3>Dashboard dnia</h3>
                    <p>Widok dnia pokazuje dostepnosc biurek, aktywnych uzytkownikow, zaplanowane urlopy i szybkie akcje.</p>
                </article>
                <article class="card">
                    <h3>Rezerwacja biurek</h3>
                    <p>System pozwala zajac wolne biurko na wybrany dzien i pilnuje konfliktow dostepnosci.</p>
                </article>
                <article class="card">
                    <h3>Model nieobecnosci</h3>
                    <p>Urlopy odejmuja dni z puli i blokowane sa pokrywajace sie zakresy dla tego samego uzytkownika.</p>
                </article>
                <article class="card">
                    <h3>Mapa biura</h3>
                    <p>Interfejs prezentuje sale i biurka w formie czytelnej, interaktywnej reprezentacji przestrzeni.</p>
                </article>
                <article class="card">
                    <h3>Przygotowanie pod HR</h3>
                    <p>Model jest gotowy do pozniejszego podpiecia HRnest bez uzalezniania rdzenia domeny od zewnetrznego API.</p>
                </article>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">Stack technologiczny</div>
                <h2>Na czym to stoi</h2>
            </div>

            <div class="tech-grid">
                <article class="tech">
                    <small>Backend</small>
                    <strong>PHP 8.4 + Symfony 7.4</strong>
                    <p>Runtime aplikacji, routing, DI, security, mailer i obsluga warstwy HTTP.</p>
                </article>
                <article class="tech">
                    <small>Architektura</small>
                    <strong>DDD + CQRS</strong>
                    <p>Podzial na Domain, Application, Infrastructure i UI oraz rozdzial command i query.</p>
                </article>
                <article class="tech">
                    <small>Persystencja</small>
                    <strong>Doctrine ORM + PostgreSQL</strong>
                    <p>Modele domenowe sa encjami Doctrine, a baza przygotowuje aplikacje do dalszego rozwoju.</p>
                </article>
                <article class="tech">
                    <small>Local Dev</small>
                    <strong>Docker + Traefik + Mailpit</strong>
                    <p>Lokalny runtime, routing po hostach i przechwytywanie maili aktywacyjnych podczas developmentu.</p>
                </article>
            </div>
        </section>

        <section class="section stack">
            <div>
                <div class="eyebrow">Przeplyw</div>
                <h2>Jak dziala aplikacja</h2>
            </div>

            <div class="timeline">
                <article class="step">
                    <div class="step-number">1</div>
                    <div>
                        <h3>Utworzenie konta</h3>
                        <p>Nowy uzytkownik rejestruje konto, podaje harmonogram dni biurowych i opcjonalnie przypisane biurko.</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">2</div>
                    <div>
                        <h3>Aktywacja przez email</h3>
                        <p>System wysyla lokalnie mail z linkiem aktywacyjnym. Bez potwierdzenia konto pozostaje nieaktywne.</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">3</div>
                    <div>
                        <h3>Plan dnia i rezerwacje</h3>
                        <p>Po zalogowaniu uzytkownik widzi status zasobow, zajmuje biurko i zarzadza swoim planem obecnosci.</p>
                    </div>
                </article>
                <article class="step">
                    <div class="step-number">4</div>
                    <div>
                        <h3>Kontrola konfliktow</h3>
                        <p>Use case'y pilnuja dostepnosci biurek, blokad wynikajacych z urlopow i ograniczen logowania.</p>
                    </div>
                </article>
            </div>
        </section>

        <p class="footer-note">
            Ta strona podsumowuje obecny stan produktu. Szczegolowe zasady domenowe i architektoniczne sa opisane w `docs/context`.
        </p>
    </div>
{% endblock %}
